@page "/login"
@rendermode InteractiveServer

@using Blazilla
@using Microsoft.EntityFrameworkCore
@using ParcleManagement.Data.Data
@using ParcleManagement.WebApps.Validator

@inject NavigationManager Navigation
@inject AppDbContext Db
@inject CustomAuthStateProvider AuthProvider

<PageTitle>Sign In — SwiftTrack</PageTitle>

<div class="login-root">
    <div class="login-card">

        <!-- Logo / Brand -->
        <div class="login-brand">
            <div class="sidebar-logo-icon">
                <img src="image/logo.jpg" alt="SwiftTrack" style="width:36px; height:36px; border-radius:6px; object-fit:cover;" />
            </div>
            <h2 class="login-animate-title">
                <span class="word">Welcome</span>
                <span class="word">Back</span>
                <span class="word">to</span>
                <span class="word highlight">SwiftSystem</span>
            </h2>
        </div>

        <!-- Error alert -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="login-alert" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                    <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z" />
                </svg>
                @errorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="login-alert login-alert-success" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                </svg>
                @successMessage
            </div>
        }

        <!-- Form -->
        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <FluentValidator />

            <!-- Email -->
            <div class="field-group">
                <label class="field-label" for="email">Email address</label>
                <div class="field-wrap">
                    <svg class="field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1zm13 2.383-4.708 2.825L15 11.105zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741M1 11.105l4.708-2.897L1 5.383z" />
                    </svg>
                    <InputText id="email"
                               class="field-input"
                               @bind-Value="loginModel.Email"
                               placeholder="you@company.com"
                               type="email"
                               autocomplete="email" />
                </div>
                <ValidationMessage For="@(() => loginModel.Email)" class="field-error" />
            </div>

            <!-- Password -->
            <div class="field-group">
                <div class="field-label-row">
                    <label class="field-label" for="password">Password</label>
                    <a href="/forgot-password" class="forgot-link">Forgot password?</a>
                </div>
                <div class="field-wrap">
                    <svg class="field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2" />
                    </svg>
                    <InputText id="password"
                               class="field-input"
                               @bind-Value="loginModel.Password"
                               placeholder="********"
                               type="@(showPassword ? "text" : "password")"
                               autocomplete="current-password" />
                    <button type="button" class="toggle-pw" @onclick="TogglePassword">
                        @if (showPassword)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z" />
                                <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829" />
                                <path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12z" />
                            </svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                            </svg>
                        }
                    </button>
                </div>
                <ValidationMessage For="@(() => loginModel.Password)" class="field-error" />
            </div>

            <!-- Remember me -->
            <div class="remember-row">
                <InputCheckbox id="rememberMe" class="remember-check" @bind-Value="loginModel.RememberMe" />
                <label for="rememberMe" class="remember-label">Keep me signed in</label>
            </div>

            <!-- Submit -->
            <button type="submit" class="submit-btn" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Signing in…</span>
                }
                else
                {
                    <span>Sign in</span>
                }
            </button>
        </EditForm>

        <p class="login-footer">
            Need access? <a href="/register" class="footer-link">Contact your admin</a>
        </p>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading = false;
    private bool showPassword = false;

    private void TogglePassword() => showPassword = !showPassword;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var user = await Db.Users.FirstOrDefaultAsync(u => u.email == loginModel.Email);

            if (user == null || !BCrypt.Net.BCrypt.Verify(loginModel.Password, user.password))
            {
                errorMessage = "Invalid email or password.";
                return;
            }

            // Auth Check Access
            AuthProvider.SetUser(new UserSession
            {
                UserId = user.ID,
                FullName = user.full_name,
                Email = user.email,
                Status = user.status
            });


            successMessage = "Login successfull Redirecting...";
            StateHasChanged();
            await Task.Delay(3000);
            Navigation.NavigateTo("/home");

        }
        catch (Exception ex)
        {
            errorMessage = "Something went wrong. Please try again.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
    /* ── Page background ── */
    .login-root {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f0f4ff;
        padding: 1.5rem;
    }

    /* ── Card ── */
    .login-card {
        width: 100%;
        max-width: 420px;
        background: #ffffff;
        border-radius: 16px;
        padding: 2.5rem 2.25rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.04), 0 12px 32px rgba(59,130,246,0.08);
    }

    .login-logo {
        width: 80px;
        height: 80px;
        border-radius: 18px;
        object-fit: cover;
    }

    /* ── Brand ── */
    .login-brand {
        text-align: center;
        margin-bottom: 2rem;
    }

    .login-icon {
        font-size: 2.4rem;
        margin-bottom: 0.5rem;
    }

    .login-icon {
        margin-bottom: 12px;
    }

    .login-animate-title {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 6px;
        font-size: 22px;
        font-weight: 600;
        margin: 0;
    }

    .word {
        display: inline-block;
        opacity: 0;
        animation: fadeSlideIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards, fadeSlideLoop 6s ease-in-out infinite;
    }

        .word:nth-child(1) {
            animation-delay: 0.2s, 3s;
        }

        .word:nth-child(2) {
            animation-delay: 0.5s, 3.15s;
        }

        .word:nth-child(3) {
            animation-delay: 0.8s, 3.3s;
        }

        .word:nth-child(4) {
            animation-delay: 1.1s, 3.45s;
        }

        .word.highlight {
            color: #1a6fdb;
        }

    @@keyframes fadeSlideIn {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes fadeSlideLoop {
        0% {
            opacity: 1;
            transform: translateX(0);
        }

        45% {
            opacity: 1;
            transform: translateX(0);
        }

        55% {
            opacity: 0;
            transform: translateX(24px);
        }

        56% {
            opacity: 0;
            transform: translateX(-24px);
        }

        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .login-subtitle {
        font-size: 0.875rem;
        color: #6b7280;
        margin: 0;
    }

    /* ── Alert ── */
    .login-alert {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-left: 3px solid #ef4444;
        border-radius: 8px;
        color: #b91c1c;
        font-size: 0.82rem;
        padding: 0.6rem 0.85rem;
        margin-bottom: 1.25rem;
    }

    /* -- Login Alert Success --*/
    .login-alert-success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-left: 3px solid #22c55e;
        color: #15803d;
    }

    /* ── Fields ── */
    .field-group {
        margin-bottom: 1.1rem;
    }

    .field-label {
        display: block;
        font-size: 0.82rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }

    .field-label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

    .field-wrap {
        position: relative;
    }

    .field-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        pointer-events: none;
    }

    .field-input {
        width: 100%;
        height: 42px;
        padding: 0 2.5rem 0 2.5rem;
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        font-size: 0.875rem;
        color: #111827;
        background: #f9fafb;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
        box-sizing: border-box;
    }

        .field-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
            background: #fff;
        }

        .field-input::placeholder {
            color: #d1d5db;
        }

    .toggle-pw {
        position: absolute;
        right: 11px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        padding: 0;
        color: #9ca3af;
        cursor: pointer;
        line-height: 1;
        transition: color 0.15s;
    }

        .toggle-pw:hover {
            color: #3b82f6;
        }

    .field-error {
        display: block;
        font-size: 0.76rem;
        color: #ef4444;
        margin-top: 4px;
    }

    .forgot-link {
        font-size: 0.76rem;
        color: #3b82f6;
        text-decoration: none;
        font-weight: 500;
    }

        .forgot-link:hover {
            text-decoration: underline;
        }

    /* ── Remember me ── */
    .remember-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1.4rem;
    }

    .remember-check {
        width: 15px;
        height: 15px;
        accent-color: #3b82f6;
        cursor: pointer;
    }

    .remember-label {
        font-size: 0.83rem;
        color: #374151;
        cursor: pointer;
        margin: 0;
    }

    /* ── Submit ── */
    .submit-btn {
        width: 100%;
        height: 44px;
        background: #2563eb;
        color: #fff;
        font-size: 0.9rem;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s, box-shadow 0.2s;
        letter-spacing: 0.01em;
    }

        .submit-btn:hover:not(:disabled) {
            background: #1d4ed8;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(37,99,235,0.3);
        }

        .submit-btn:active:not(:disabled) {
            transform: translateY(0);
        }

        .submit-btn:disabled {
            background: #93c5fd;
            cursor: not-allowed;
        }

    /* ── Footer ── */
    .login-footer {
        text-align: center;
        font-size: 0.82rem;
        color: #9ca3af;
        margin: 1.25rem 0 0;
    }

    .footer-link {
        color: #2563eb;
        font-weight: 600;
        text-decoration: none;
    }

        .footer-link:hover {
            text-decoration: underline;
        }

    @@media (max-width: 480px) {
        .login-card {
            padding: 2rem 1.25rem;
        }
    }
</style>
