@page "/services"
@layout MainLayout
@rendermode InteractiveServer

@using ParcleManagement.Data.Data
@using ParcleManagement.Data.Models
@using Microsoft.EntityFrameworkCore

@inject AppDbContext Db

<PageTitle>Service Types — SwiftTrack</PageTitle>

<div class="st-page-header">
    <div>
        <h1 class="st-page-title">Service Types</h1>
        <p class="st-page-sub">Manage delivery service types and pricing</p>
    </div>
    <button class="st-btn st-btn-primary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        New Service Type
    </button>
</div>

@if (isLoading)
{
    <div class="loading-wrap">
        <div class="spinner-border text-primary" role="status"></div>
        <span>Loading service types...</span>
    </div>
}
else if (serviceTypes.Count == 0)
{
    <div class="empty-state">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="8" y1="6" x2="21" y2="6" />
            <line x1="8" y1="12" x2="21" y2="12" />
            <line x1="8" y1="18" x2="21" y2="18" />
            <line x1="3" y1="6" x2="3.01" y2="6" />
            <line x1="3" y1="12" x2="3.01" y2="12" />
            <line x1="3" y1="18" x2="3.01" y2="18" />
        </svg>
        <p>No service types found. Add your first one.</p>
    </div>
}
else
{
    <div class="service-grid">
        @foreach (var service in serviceTypes)
        {
            <div class="st-card service-card">
                <div class="service-card-header">
                    <div class="service-icon @GetServiceColor(service.code)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                        </svg>
                    </div>
                    <div>
                        <div class="service-name">@service.name</div>
                        <span class="st-badge @GetBadgeColor(service.code)">@service.code</span>
                    </div>
                    <div class="service-status">
                        @if (service.is_active)
                        {
                            <span class="st-badge st-badge-green">Active</span>
                        }
                        else
                        {
                            <span class="st-badge st-badge-gray">Inactive</span>
                        }
                    </div>
                </div>

                <div class="service-card-body">
                    <p class="service-desc">@service.description</p>
                    <div class="service-pricing">
                        <div class="pricing-item">
                            <span class="pricing-label">Rate per kg</span>
                            <span class="pricing-value">$@service.base_rate_per_kg.ToString("0.00")</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Minimum charge</span>
                            <span class="pricing-value">$@service.minimum_charge.ToString("0.00")</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Volumetric divisor</span>
                            <span class="pricing-value">@service.volumetric_divisor</span>
                        </div>
                    </div>
                </div>

                <div class="service-card-footer">
                    <button class="st-btn st-btn-ghost" style="font-size:12px; padding:5px 10px;">Edit</button>
                    <button class="st-btn @(service.is_active ? "st-btn-outline" : "st-btn-primary")"
                            style="font-size:12px; padding:5px 10px;">
                        @(service.is_active ? "Deactivate" : "Activate")
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<ServiceType> serviceTypes = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        serviceTypes = await Db.ServiceTypes
            .OrderBy(s => s.ID)
            .ToListAsync();
        isLoading = false;
    }

    private string GetServiceColor(string code) => code switch
    {
        "standard" => "service-icon-blue",
        "express" => "service-icon-amber",
        "overnight" => "service-icon-red",
        _ => "service-icon-blue"
    };

    private string GetBadgeColor(string code) => code switch
    {
        "standard" => "st-badge-blue",
        "express" => "st-badge-amber",
        "overnight" => "st-badge-red",
        _ => "st-badge-gray"
    };
}

<style>
    .st-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .loading-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 40px;
        color: var(--text-secondary);
        justify-content: center;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 60px;
        color: var(--text-secondary);
        text-align: center;
    }

    .service-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .service-card {
        display: flex;
        flex-direction: column;
    }

    .service-card-header {
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        border-bottom: 1px solid var(--border-color);
    }

    .service-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .service-icon-blue {
        background: var(--blue-light);
        color: var(--blue-primary);
    }

    .service-icon-amber {
        background: #fff8e6;
        color: #b45309;
    }

    .service-icon-red {
        background: #fef2f2;
        color: #dc2626;
    }

    .service-name {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .service-status {
        margin-left: auto;
    }

    .service-card-body {
        padding: 16px 20px;
        flex: 1;
    }

    .service-desc {
        font-size: 13px;
        color: var(--text-secondary);
        margin-bottom: 16px;
        line-height: 1.5;
    }

    .service-pricing {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .pricing-item {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
    }

    .pricing-label {
        color: var(--text-secondary);
    }

    .pricing-value {
        font-weight: 600;
        color: var(--text-primary);
    }

    .service-card-footer {
        padding: 14px 20px;
        border-top: 1px solid var(--border-color);
        display: flex;
        justify-content: flex-end;
        gap: 8px;
    }

    @@media (max-width: 900px) {
        .service-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 600px) {
        .service-grid {
            grid-template-columns: 1fr;
        }
    }
</style>