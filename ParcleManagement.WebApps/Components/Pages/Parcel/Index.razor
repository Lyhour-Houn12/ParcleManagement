@page "/parcels"
@using ParcleManagement.Data.entity
@using ParcleManagement.Data.db_migration
@inject ParcleDbContext Db
@inject NavigationManager Nav
@using Microsoft.EntityFrameworkCore

<PageTitle>Parcels — ParcleMS</PageTitle>

<!-- Stats row -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="flex-center">
            <div>
                <div class="stat-label">Total Parcels</div>
                <div class="stat-value">@_totalCount</div>
            </div>
            <div class="stat-icon ml-auto" style="background:#e8f1fd;color:#1a6fdb">📦</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="flex-center">
            <div>
                <div class="stat-label">Pending</div>
                <div class="stat-value">@_pendingCount</div>
            </div>
            <div class="stat-icon ml-auto" style="background:#fef9c3;color:#854d0e">⏳</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="flex-center">
            <div>
                <div class="stat-label">In Transit</div>
                <div class="stat-value">@_transitCount</div>
            </div>
            <div class="stat-icon ml-auto" style="background:#dbeafe;color:#1e40af">🚚</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="flex-center">
            <div>
                <div class="stat-label">Delivered</div>
                <div class="stat-value">@_deliveredCount</div>
            </div>
            <div class="stat-icon ml-auto" style="background:#dcfce7;color:#166534">✅</div>
        </div>
    </div>
</div>

<!-- Table card -->
<div class="st-card">
    <!-- Toolbar -->
    <div class="st-toolbar">
        <div class="st-search">
            <span style="color:var(--text-secondary);font-size:14px">🔍</span>
            <input placeholder="Search tracking number, customer…"
                   @bind="_searchQuery" @bind:event="oninput"
                   @onkeyup="ApplyFilter" />
        </div>

        <select class="st-select" @bind="_statusFilter" @bind:after="ApplyFilter">
            <option value="">All Status</option>
            <option value="pending">Pending</option>
            <option value="transit">In Transit</option>
            <option value="delivered">Delivered</option>
            <option value="failed">Failed</option>
            <option value="cancelled">Cancelled</option>
        </select>

        <select class="st-select" @bind="_serviceFilter" @bind:after="ApplyFilter">
            <option value="">All Services</option>
            @foreach (var svc in _serviceTypes)
            {
                <option value="@svc.Id">@svc.Name</option>
            }
        </select>

        <div class="ml-auto">
            <a href="/parcels/create" class="btn btn-primary">
                ➕ New Parcel
            </a>
        </div>
    </div>

    <!-- Table -->
    <div style="overflow-x:auto">
        <table class="st-table">
            <thead>
                <tr>
                    <th>Tracking #</th>
                    <th>Customer</th>
                    <th>Driver</th>
                    <th>Service</th>
                    <th>Weight</th>
                    <th>COD</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (_parcels.Count == 0)
                {
                    <tr>
                        <td colspan="9">
                            <div class="empty-state">
                                <div class="empty-icon">📭</div>
                                <p>No parcels found.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var p in _parcels)
                    {
                        <tr>
                            <td>
                                <span class="tracking-number">@p.TrackingNumber</span>
                            </td>
                            <td>
                                <div class="flex-center gap-8">
                                    <div class="avatar">@Initials(p.Customer?.FullName)</div>
                                    <span>@p.Customer?.FullName</span>
                                </div>
                            </td>
                            <td>@(p.Driver?.Name ?? "—")</td>
                            <td>@p.ServiceType?.Name</td>
                            <td>@p.Weight kg</td>
                            <td>$@p.CodAmount.ToString("N2")</td>
                            <td><span class="badge @StatusBadge(p.Status)">@p.Status</span></td>
                            <td class="text-muted">@p.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="flex-center gap-8">
                                    <a href="/parcels/@p.Id" class="btn-icon" title="View">👁</a>
                                    <a href="/parcels/@p.Id/edit" class="btn-icon" title="Edit">✏️</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="st-pagination">
        <span>Showing @((_page - 1) * _pageSize + 1)–@Math.Min(_page * _pageSize, _filteredTotal) of @_filteredTotal</span>
        <div class="pagination-pages">
            <button class="page-btn" disabled="@(_page <= 1)" @onclick="PrevPage">‹</button>
            @for (int i = 1; i <= TotalPages; i++)
            {
                var p = i;
                <button class="page-btn @(p == _page ? "active" : "")" @onclick="() => GoPage(p)">@p</button>
            }
            <button class="page-btn" disabled="@(_page >= TotalPages)" @onclick="NextPage">›</button>
        </div>
    </div>
</div>

@code {
    private List<Parcel> _parcels = new();
    private List<ServiceType> _serviceTypes = new();

    private string _searchQuery = "";
    private string _statusFilter = "";
    private string _serviceFilter = "";

    private int _totalCount, _pendingCount, _transitCount, _deliveredCount;
    private int _filteredTotal, _page = 1, _pageSize = 10;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_filteredTotal / (double)_pageSize));

    protected override async Task OnInitializedAsync()
    {
        _serviceTypes = await Db.ServiceTypes.ToListAsync();
        await LoadStats();
        await LoadParcels();
    }

    private async Task LoadStats()
    {
        _totalCount     = await Db.Parcels.CountAsync();
        _pendingCount   = await Db.Parcels.CountAsync(p => p.Status == "pending");
        _transitCount   = await Db.Parcels.CountAsync(p => p.Status == "transit");
        _deliveredCount = await Db.Parcels.CountAsync(p => p.Status == "delivered");
    }

    private async Task LoadParcels()
    {
        var q = Db.Parcels
            .Include(p => p.Customer)
            .Include(p => p.Driver)
            .Include(p => p.ServiceType)
            .AsQueryable();

        if (!string.IsNullOrWhiteSpace(_searchQuery))
            q = q.Where(p => p.TrackingNumber.Contains(_searchQuery)
                           || p.Customer!.FullName.Contains(_searchQuery));

        if (!string.IsNullOrWhiteSpace(_statusFilter))
            q = q.Where(p => p.Status == _statusFilter);

        if (!string.IsNullOrWhiteSpace(_serviceFilter) && int.TryParse(_serviceFilter, out var sid))
            q = q.Where(p => p.ServiceTypeId == sid);

        _filteredTotal = await q.CountAsync();
        _parcels = await q
            .OrderByDescending(p => p.CreatedAt)
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToListAsync();
    }

    private async Task ApplyFilter()
    {
        _page = 1;
        await LoadParcels();
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadParcels(); } }
    private async Task NextPage() { if (_page < TotalPages) { _page++; await LoadParcels(); } }
    private async Task GoPage(int p) { _page = p; await LoadParcels(); }

    private static string StatusBadge(string? s) => s switch
    {
        "pending"   => "badge-pending",
        "transit"   => "badge-transit",
        "delivered" => "badge-delivered",
        "failed"    => "badge-failed",
        "cancelled" => "badge-cancelled",
        _ => "badge-pending"
    };

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name[..1].ToUpper();
    }
}
