@page "/assignments"
@layout MainLayout
@rendermode InteractiveServer

<PageTitle>Assignments — SwiftTrack</PageTitle>

<div class="st-page-header">
    <div>
        <h1 class="st-page-title">Assignments</h1>
        <p class="st-page-sub">Assign parcels to drivers and manage delivery tasks</p>
    </div>
    <button class="st-btn st-btn-primary" @onclick="@(() => showForm = true)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        New Assignment
    </button>
</div>

<!-- Stats Row -->
<div class="assign-stats">
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-blue">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
        </div>
        <div>
            <div class="stat-value">128</div>
            <div class="stat-label">Total Assignments</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-amber">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
        </div>
        <div>
            <div class="stat-value">47</div>
            <div class="stat-label">In Progress</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
        </div>
        <div>
            <div class="stat-value">74</div>
            <div class="stat-label">Completed</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
        </div>
        <div>
            <div class="stat-value">7</div>
            <div class="stat-label">Unassigned</div>
        </div>
    </div>
</div>

<!-- New Assignment Modal -->
@if (showForm)
{
    <div class="modal-backdrop" @onclick="@(() => showForm = false)">
        <div class="modal-card" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="st-page-title" style="font-size:16px;">New Assignment</h2>
                <button class="st-btn st-btn-ghost" style="padding:4px 8px;" @onclick="@(() => showForm = false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Tracking ID</label>
                    <input class="form-input" type="text" placeholder="e.g. TRK-001240" @bind="form.TrackingId" />
                </div>
                <div class="form-group">
                    <label class="form-label">Driver</label>
                    <select class="form-input" @bind="form.DriverName">
                        <option value="">Select driver...</option>
                        @foreach (var d in drivers)
                        {
                            <option value="@d">@d</option>
                        }
                    </select>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Pickup Location</label>
                        <input class="form-input" type="text" placeholder="Origin hub / address" @bind="form.Pickup" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Delivery Location</label>
                        <input class="form-input" type="text" placeholder="Destination address" @bind="form.Delivery" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Scheduled Date</label>
                        <input class="form-input" type="date" @bind="form.ScheduledDate" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Priority</label>
                        <select class="form-input" @bind="form.Priority">
                            <option value="Normal">Normal</option>
                            <option value="High">High</option>
                            <option value="Urgent">Urgent</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Notes</label>
                    <textarea class="form-input" rows="2" placeholder="Optional notes for driver..." @bind="form.Notes"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="st-btn st-btn-ghost" @onclick="@(() => showForm = false)">Cancel</button>
                <button class="st-btn st-btn-primary" @onclick="HandleSubmit">Create Assignment</button>
            </div>
        </div>
    </div>
}

<!-- Main Table -->
<div class="st-card" style="margin-top:24px;">
    <div class="st-card-header">
        <h2 class="st-page-title" style="font-size:16px;">All Assignments</h2>
        <div style="display:flex; gap:10px; align-items:center;">
            <div class="st-search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search assignments..." @bind="searchQuery" @bind:event="oninput" />
            </div>
            <select class="st-select" @bind="statusFilter">
                <option value="">All Status</option>
                <option value="Pending">Pending</option>
                <option value="In Progress">In Progress</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
            </select>
            <select class="st-select" @bind="priorityFilter">
                <option value="">All Priority</option>
                <option value="Normal">Normal</option>
                <option value="High">High</option>
                <option value="Urgent">Urgent</option>
            </select>
        </div>
    </div>
    <div class="st-card-body" style="padding:0;">
        <table class="st-table">
            <thead>
                <tr>
                    <th>Assignment ID</th>
                    <th>Tracking ID</th>
                    <th>Driver</th>
                    <th>Pickup</th>
                    <th>Delivery</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Scheduled</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in FilteredAssignments)
                {
                    <tr>
                        <td><span class="assign-id">@a.AssignmentId</span></td>
                        <td><span class="tracking-id">@a.TrackingId</span></td>
                        <td>
                            <div class="driver-cell">
                                <div class="driver-avatar-sm">@GetInitials(a.DriverName)</div>
                                @a.DriverName
                            </div>
                        </td>
                        <td>@a.Pickup</td>
                        <td>@a.Delivery</td>
                        <td><span class="st-badge @GetPriorityBadge(a.Priority)">@a.Priority</span></td>
                        <td><span class="st-badge @GetStatusBadge(a.Status)">@a.Status</span></td>
                        <td>@a.ScheduledDate</td>
                        <td>
                            <div style="display:flex; gap:6px;">
                                <button class="st-btn st-btn-ghost" style="padding:4px 8px; font-size:12px;">View</button>
                                <button class="st-btn st-btn-outline" style="padding:4px 8px; font-size:12px;">Edit</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private string searchQuery = "";
    private string statusFilter = "";
    private string priorityFilter = "";
    private bool showForm = false;

    private AssignmentForm form = new();

    private List<string> drivers = new()
    {
        "Kheang Vuth", "Panha Srun", "Dara Heng", "Sokha Meas", "Chanra Lim", "Borin Keo"
    };

    private string GetInitials(string name)
    {
        var parts = name.Split(' ');
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : name[..1];
    }

    private void HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.TrackingId) || string.IsNullOrWhiteSpace(form.DriverName)) return;

        assignments.Insert(0, new AssignmentItem(
            $"ASN-{Random.Shared.Next(10000, 99999)}",
            form.TrackingId.Trim(),
            form.DriverName,
            string.IsNullOrWhiteSpace(form.Pickup) ? "Phnom Penh Hub" : form.Pickup,
            string.IsNullOrWhiteSpace(form.Delivery) ? "—" : form.Delivery,
            form.Priority,
            "Pending",
            form.ScheduledDate == default ? DateTime.Now.ToString("yyyy-MM-dd") : form.ScheduledDate.ToString("yyyy-MM-dd")
        ));

        form = new();
        showForm = false;
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Completed" => "st-badge-green",
        "In Progress" => "st-badge-blue",
        "Pending" => "st-badge-amber",
        "Cancelled" => "st-badge-red",
        _ => "st-badge-gray"
    };

    private string GetPriorityBadge(string priority) => priority switch
    {
        "Urgent" => "st-badge-red",
        "High" => "st-badge-amber",
        _ => "st-badge-gray"
    };

    private IEnumerable<AssignmentItem> FilteredAssignments => assignments
        .Where(a =>
            (string.IsNullOrEmpty(searchQuery) ||
             a.AssignmentId.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
             a.TrackingId.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
             a.DriverName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
             a.Pickup.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
             a.Delivery.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(statusFilter) ||
             a.Status.Equals(statusFilter, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(priorityFilter) ||
             a.Priority.Equals(priorityFilter, StringComparison.OrdinalIgnoreCase))
        );

    record AssignmentItem(
        string AssignmentId, string TrackingId, string DriverName,
        string Pickup, string Delivery, string Priority,
        string Status, string ScheduledDate);

    class AssignmentForm
    {
        public string TrackingId { get; set; } = "";
        public string DriverName { get; set; } = "";
        public string Pickup { get; set; } = "";
        public string Delivery { get; set; } = "";
        public string Priority { get; set; } = "Normal";
        public string Notes { get; set; } = "";
        public DateTime ScheduledDate { get; set; } = DateTime.Now;
    }

    private List<AssignmentItem> assignments = new()
    {
        new("ASN-10021", "TRK-001239", "Panha Srun",  "Phnom Penh Hub",   "Phnom Penh, Street 93",   "Urgent", "In Progress", "2026-06-17"),
        new("ASN-10020", "TRK-001238", "Sokha Meas",  "Phnom Penh Hub",   "Takeo Central Market",    "Normal", "Completed",   "2026-06-13"),
        new("ASN-10019", "TRK-001237", "Dara Heng",   "Phnom Penh Hub",   "Kampot, Street 4",        "High",   "Cancelled",   "2026-06-14"),
        new("ASN-10018", "TRK-001236", "Unassigned",  "Phnom Penh Hub",   "Battambang Hub",          "Normal", "Pending",     "2026-06-19"),
        new("ASN-10017", "TRK-001235", "Panha Srun",  "Phnom Penh Hub",   "Siem Reap Hub",           "Normal", "In Progress", "2026-06-16"),
        new("ASN-10016", "TRK-001234", "Kheang Vuth", "Phnom Penh Hub",   "Phnom Penh, Street 271",  "High",   "Completed",   "2026-06-15"),
        new("ASN-10015", "TRK-001233", "Chanra Lim",  "Siem Reap Hub",    "Siem Reap, Pub Street",   "Normal", "Completed",   "2026-06-12"),
        new("ASN-10014", "TRK-001232", "Borin Keo",   "Battambang Hub",   "Battambang, Road 5",      "Urgent", "Completed",   "2026-06-11"),
        new("ASN-10013", "TRK-001231", "Dara Heng",   "Kampot Hub",       "Kampot Beach Resort",     "Normal", "Pending",     "2026-06-18"),
        new("ASN-10012", "TRK-001230", "Kheang Vuth", "Phnom Penh Hub",   "Kandal Province",         "High",   "In Progress", "2026-06-17"),
    };
}

<style>
    .st-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    /* ── Stats ── */
    .assign-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-icon-blue {
        background: var(--blue-light);
        color: var(--blue-primary);
    }

    .stat-icon-green {
        background: #e6f9f0;
        color: #1a8a4a;
    }

    .stat-icon-amber {
        background: #fff8e6;
        color: #b45309;
    }

    .stat-icon-red {
        background: #fef2f2;
        color: #dc2626;
    }

    .stat-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1;
    }

    .stat-label {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 3px;
    }

    /* ── Modal ── */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.35);
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-card {
        background: #fff;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        width: 520px;
        max-width: calc(100vw - 32px);
        display: flex;
        flex-direction: column;
        max-height: calc(100vh - 48px);
        overflow: hidden;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px;
        border-bottom: 1px solid var(--border-color);
    }

    .modal-body {
        padding: 24px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border-color);
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    /* ── Form ── */
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
    }

    .form-row {
        display: flex;
        gap: 16px;
    }

    .form-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--text-secondary);
    }

    .form-input {
        padding: 9px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        color: var(--text-primary);
        background: #fff;
        outline: none;
        width: 100%;
        font-family: inherit;
        transition: border-color .15s, box-shadow .15s;
        resize: none;
    }

        .form-input:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    /* ── Table extras ── */
    .assign-id {
        font-family: monospace;
        font-size: 13px;
        color: var(--text-secondary);
        font-weight: 600;
    }

    .tracking-id {
        font-family: monospace;
        font-size: 13px;
        color: var(--blue-primary);
        font-weight: 600;
    }

    .driver-cell {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .driver-avatar-sm {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--blue-light);
        color: var(--blue-primary);
        font-size: 11px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .st-select {
        padding: 8px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        background: #fff;
        color: var(--text-primary);
        outline: none;
        cursor: pointer;
    }

        .st-select:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    @@media (max-width: 768px) {
        .assign-stats {
            grid-template-columns: repeat(2, 1fr);
        }

        .form-row {
            flex-direction: column;
        }
    }
</style>
