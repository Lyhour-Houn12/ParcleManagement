@rendermode InteractiveServer

@if (IsVisible && Parcel != null)
{
    <div class="detail-overlay">
        <div class="detail-modal">
            <!-- Header -->
            <div class="detail-header">
                <div>
                    <div class="detail-tracking">@Parcel.TrackingId</div>
                    <span class="st-badge @GetStatusBadge(Parcel.Status)">@Parcel.Status</span>
                </div>
                <button class="detail-close" @onclick="HandleClose">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>

            <!-- Body -->
            <div class="detail-body">

                <!-- Timeline -->
                <div class="detail-timeline">
                    <div class="timeline-step @(IsStepDone("Pending") ? "done" : "") @(IsStepActive("Pending") ? "active" : "")">
                        <div class="timeline-dot"></div>
                        <div class="timeline-label">Pending</div>
                    </div>
                    <div class="timeline-line"></div>
                    <div class="timeline-step @(IsStepDone("In Transit") ? "done" : "") @(IsStepActive("In Transit") ? "active" : "")">
                        <div class="timeline-dot"></div>
                        <div class="timeline-label">In Transit</div>
                    </div>
                    <div class="timeline-line"></div>
                    <div class="timeline-step @(IsStepDone("Delivered") ? "done" : "") @(IsStepActive("Delivered") ? "active" : "")">
                        <div class="timeline-dot"></div>
                        <div class="timeline-label">Delivered</div>
                    </div>
                </div>

                <!-- Info Grid -->
                <div class="detail-grid">
                    <!-- Sender -->
                    <div class="detail-section">
                        <div class="detail-section-title">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                            Sender
                        </div>
                        <div class="detail-info-card">
                            <div class="detail-row">
                                <span class="detail-label">Name</span>
                                <span class="detail-value">@Parcel.Sender</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Date</span>
                                <span class="detail-value">@Parcel.Date</span>
                            </div>
                        </div>
                    </div>

                    <!-- Recipient -->
                    <div class="detail-section">
                        <div class="detail-section-title">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                <circle cx="12" cy="10" r="3" />
                            </svg>
                            Recipient
                        </div>
                        <div class="detail-info-card">
                            <div class="detail-row">
                                <span class="detail-label">Name</span>
                                <span class="detail-value">@Parcel.Recipient</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Destination</span>
                                <span class="detail-value">@Parcel.Destination</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Parcel Info -->
                <div class="detail-section" style="margin-top:16px;">
                    <div class="detail-section-title">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                        </svg>
                        Parcel Info
                    </div>
                    <div class="detail-info-card">
                        <div class="detail-row">
                            <span class="detail-label">Tracking ID</span>
                            <span class="detail-value tracking-id">@Parcel.TrackingId</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Status</span>
                            <span class="st-badge @GetStatusBadge(Parcel.Status)">@Parcel.Status</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Created</span>
                            <span class="detail-value">@Parcel.Date</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Footer -->
            <div class="detail-footer">
                <button class="st-btn st-btn-ghost" @onclick="HandleClose">Close</button>
                <button class="st-btn st-btn-outline">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                    </svg>
                    Export
                </button>
                <button class="st-btn st-btn-primary">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                    </svg>
                    Edit Parcel
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public ParcelItemDetail? Parcel { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task HandleClose() => await OnClose.InvokeAsync();

    private string GetStatusBadge(string status) => status switch
    {
        "Delivered" => "st-badge-green",
        "In Transit" => "st-badge-blue",
        "Pending" => "st-badge-amber",
        "Failed" => "st-badge-red",
        _ => "st-badge-gray"
    };

    private bool IsStepDone(string step)
    {
        if (Parcel == null) return false;
        return step switch
        {
            "Pending" => Parcel.Status is "In Transit" or "Delivered",
            "In Transit" => Parcel.Status is "Delivered",
            _ => false
        };
    }

    private bool IsStepActive(string step) => Parcel?.Status == step;

    public class ParcelItemDetail
    {
        public string TrackingId { get; set; } = "";
        public string Sender { get; set; } = "";
        public string Recipient { get; set; } = "";
        public string Destination { get; set; } = "";
        public string Status { get; set; } = "";
        public string Date { get; set; } = "";
    }
}

<style>
    .detail-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(3px);
    }

    .detail-modal {
        background: var(--white);
        border-radius: var(--radius-lg);
        width: 580px;
        max-height: 85vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        animation: popIn 0.2s ease;
    }

    @@keyframes popIn {
        from {
            transform: translateY(-10px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .detail-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
    }

    .detail-tracking {
        font-size: 18px;
        font-weight: 700;
        color: var(--blue-primary);
        font-family: monospace;
        margin-bottom: 6px;
    }

    .detail-close {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--text-secondary);
        padding: 4px;
        border-radius: var(--radius-sm);
        transition: background 0.15s, color 0.15s;
    }

        .detail-close:hover {
            background: var(--bg-page);
            color: var(--text-primary);
        }

    .detail-body {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
    }

    /* Timeline */
    .detail-timeline {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 28px;
        gap: 0;
    }

    .timeline-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }

    .timeline-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 2px solid var(--border-color);
        background: var(--white);
        transition: all 0.2s;
    }

    .timeline-step.done .timeline-dot {
        background: #22c55e;
        border-color: #22c55e;
    }

    .timeline-step.active .timeline-dot {
        background: var(--blue-primary);
        border-color: var(--blue-primary);
        box-shadow: 0 0 0 4px rgba(26,111,219,0.15);
    }

    .timeline-label {
        font-size: 11px;
        font-weight: 500;
        color: var(--text-secondary);
        white-space: nowrap;
    }

    .timeline-step.done .timeline-label,
    .timeline-step.active .timeline-label {
        color: var(--text-primary);
        font-weight: 600;
    }

    .timeline-line {
        flex: 1;
        height: 2px;
        background: var(--border-color);
        margin: 0 8px;
        margin-bottom: 20px;
        min-width: 60px;
    }

    /* Info sections */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .detail-section-title {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--text-secondary);
        margin-bottom: 10px;
    }

    .detail-info-card {
        background: var(--bg-page);
        border-radius: var(--radius-md);
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        border: 1px solid var(--border-color);
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
    }

    .detail-label {
        color: var(--text-secondary);
        font-weight: 500;
    }

    .detail-value {
        color: var(--text-primary);
        font-weight: 500;
        text-align: right;
    }

    .detail-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border-color);
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    @@media (max-width: 600px) {
        .detail-modal {
            width: 95vw;
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }
    }
</style>