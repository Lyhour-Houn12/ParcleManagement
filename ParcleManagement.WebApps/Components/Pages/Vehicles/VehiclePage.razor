@page "/vehicles"
@layout MainLayout
@rendermode InteractiveServer

<PageTitle>Vehicles — SwiftTrack</PageTitle>

<div class="st-page-header">
    <div>
        <h1 class="st-page-title">Vehicles</h1>
        <p class="st-page-sub">Manage fleet vehicles and maintenance status</p>
    </div>
    <button class="st-btn st-btn-primary" @onclick="@(() => showForm = true)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        Add Vehicle
    </button>
</div>

<!-- Stats -->
<div class="vehicle-stats">
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-blue">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2" /><path d="M16 8h4l3 5v3h-7V8z" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" /></svg>
        </div>
        <div>
            <div class="stat-value">36</div>
            <div class="stat-label">Total Vehicles</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
        </div>
        <div>
            <div class="stat-value">22</div>
            <div class="stat-label">Active</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-amber">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>
        </div>
        <div>
            <div class="stat-value">9</div>
            <div class="stat-label">In Maintenance</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="4.93" y1="4.93" x2="19.07" y2="19.07" /></svg>
        </div>
        <div>
            <div class="stat-value">5</div>
            <div class="stat-label">Retired</div>
        </div>
    </div>
</div>

<!-- Modal -->
@if (showForm)
{
    <div class="modal-backdrop" @onclick="@(() => showForm = false)">
        <div class="modal-card" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="st-page-title" style="font-size:16px;">Add Vehicle</h2>
                <button class="st-btn st-btn-ghost" style="padding:4px 8px;" @onclick="@(() => showForm = false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Plate Number</label>
                        <input class="form-input" type="text" placeholder="e.g. PP-1234" @bind="form.Plate" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Type</label>
                        <select class="form-input" @bind="form.Type">
                            <option value="Motorbike">Motorbike</option>
                            <option value="Van">Van</option>
                            <option value="Truck">Truck</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Brand / Model</label>
                        <input class="form-input" type="text" placeholder="e.g. Toyota Hiace" @bind="form.Model" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Year</label>
                        <input class="form-input" type="number" placeholder="e.g. 2022" @bind="form.Year" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Assigned Driver</label>
                        <select class="form-input" @bind="form.Driver">
                            <option value="Unassigned">Unassigned</option>
                            <option value="Kheang Vuth">Kheang Vuth</option>
                            <option value="Panha Srun">Panha Srun</option>
                            <option value="Dara Heng">Dara Heng</option>
                            <option value="Sokha Meas">Sokha Meas</option>
                            <option value="Chanra Lim">Chanra Lim</option>
                            <option value="Borin Keo">Borin Keo</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Capacity (kg)</label>
                        <input class="form-input" type="number" placeholder="e.g. 500" @bind="form.Capacity" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Last Service Date</label>
                        <input class="form-input" type="date" @bind="form.LastService" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Zone</label>
                        <select class="form-input" @bind="form.Zone">
                            <option value="Phnom Penh">Phnom Penh</option>
                            <option value="Siem Reap">Siem Reap</option>
                            <option value="Battambang">Battambang</option>
                            <option value="Kampot">Kampot</option>
                            <option value="Takeo">Takeo</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="st-btn st-btn-ghost" @onclick="@(() => showForm = false)">Cancel</button>
                <button class="st-btn st-btn-primary" @onclick="HandleSubmit">Add Vehicle</button>
            </div>
        </div>
    </div>
}

<!-- Vehicle Cards -->
<div class="vehicle-grid" style="margin-top:24px;">
    @foreach (var v in FilteredVehicles)
    {
        <div class="st-card vehicle-card">
            <div class="vehicle-card-top">
                <div class="vehicle-icon-wrap @GetTypeColor(v.Type)">
                    @if (v.Type == "Motorbike")
                    {
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5.5" cy="17.5" r="3.5" /><circle cx="18.5" cy="17.5" r="3.5" /><path d="M15 6h-5l-3 7h11l-3-7z" /><path d="M15 6l2 4" /></svg>
                    }
                    else if (v.Type == "Van")
                    {
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2" /><path d="M16 8h4l3 5v3h-7V8z" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" /></svg>
                    }
                    else
                    {
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="6" width="22" height="12" rx="2" /><path d="M1 12h22" /><circle cx="6" cy="20" r="2" /><circle cx="18" cy="20" r="2" /></svg>
                    }
                </div>
                <div style="flex:1; min-width:0;">
                    <div class="vehicle-plate">@v.Plate</div>
                    <div class="vehicle-model">@v.Model · @v.Year</div>
                </div>
                <span class="st-badge @GetStatusBadge(v.Status)">@v.Status</span>
            </div>
            <div class="vehicle-divider"></div>
            <div class="vehicle-info-grid">
                <div class="vinfo-item">
                    <span class="info-label">Type</span>
                    <span class="info-value">@v.Type</span>
                </div>
                <div class="vinfo-item">
                    <span class="info-label">Capacity</span>
                    <span class="info-value">@v.Capacity kg</span>
                </div>
                <div class="vinfo-item">
                    <span class="info-label">Driver</span>
                    <span class="info-value">@v.Driver</span>
                </div>
                <div class="vinfo-item">
                    <span class="info-label">Zone</span>
                    <span class="info-value">@v.Zone</span>
                </div>
                <div class="vinfo-item" style="grid-column:span 2;">
                    <span class="info-label">Last Service</span>
                    <span class="info-value">@v.LastService</span>
                </div>
            </div>
            <div class="vehicle-card-footer">
                <button class="st-btn st-btn-ghost" style="font-size:12px; padding:5px 10px; flex:1;">View</button>
                <button class="st-btn st-btn-outline" style="font-size:12px; padding:5px 10px; flex:1;">Edit</button>
                <button class="st-btn st-btn-ghost" style="font-size:12px; padding:5px 10px; flex:1; color:#b45309;"
                        @onclick="@(() => SetMaintenance(v))">
                    Service
                </button>
            </div>
        </div>
    }
</div>

<!-- Table -->
<div class="st-card" style="margin-top:24px;">
    <div class="st-card-header">
        <h2 class="st-page-title" style="font-size:16px;">All Vehicles</h2>
        <div style="display:flex; gap:10px; align-items:center;">
            <div class="st-search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search vehicles..." @bind="searchQuery" @bind:event="oninput" />
            </div>
            <select class="st-select" @bind="typeFilter">
                <option value="">All Types</option>
                <option value="Motorbike">Motorbike</option>
                <option value="Van">Van</option>
                <option value="Truck">Truck</option>
            </select>
            <select class="st-select" @bind="statusFilter">
                <option value="">All Status</option>
                <option value="Active">Active</option>
                <option value="In Maintenance">In Maintenance</option>
                <option value="Retired">Retired</option>
            </select>
        </div>
    </div>
    <div class="st-card-body" style="padding:0;">
        <table class="st-table">
            <thead>
                <tr>
                    <th>Plate</th>
                    <th>Type</th>
                    <th>Model</th>
                    <th>Year</th>
                    <th>Driver</th>
                    <th>Capacity</th>
                    <th>Zone</th>
                    <th>Last Service</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in FilteredVehicles)
                {
                    <tr>
                        <td><span class="plate-tag">@v.Plate</span></td>
                        <td>
                            <span class="type-chip @GetTypeColor(v.Type)">@v.Type</span>
                        </td>
                        <td style="font-weight:500;">@v.Model</td>
                        <td>@v.Year</td>
                        <td>@v.Driver</td>
                        <td>@v.Capacity kg</td>
                        <td>@v.Zone</td>
                        <td>@v.LastService</td>
                        <td><span class="st-badge @GetStatusBadge(v.Status)">@v.Status</span></td>
                        <td>
                            <div style="display:flex; gap:6px;">
                                <button class="st-btn st-btn-ghost" style="padding:4px 8px; font-size:12px;">View</button>
                                <button class="st-btn st-btn-outline" style="padding:4px 8px; font-size:12px;">Edit</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private string searchQuery = "";
    private string typeFilter = "";
    private string statusFilter = "";
    private bool showForm = false;
    private VehicleForm form = new();

    private string GetStatusBadge(string s) => s switch
    {
        "Active" => "st-badge-green",
        "In Maintenance" => "st-badge-amber",
        _ => "st-badge-gray"
    };

    private string GetTypeColor(string t) => t switch
    {
        "Motorbike" => "type-blue",
        "Van" => "type-green",
        _ => "type-amber"
    };

    private void SetMaintenance(VehicleItem v)
    {
        var idx = vehicles.IndexOf(v);
        vehicles[idx] = v with
        {
            Status = v.Status == "In Maintenance" ? "Active" : "In Maintenance",
            LastService = v.Status == "In Maintenance" ? DateTime.Now.ToString("yyyy-MM-dd") : v.LastService
        };
    }

    private void HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.Plate)) return;
        vehicles.Insert(0, new VehicleItem(
            form.Plate.ToUpper(),
            form.Type,
            string.IsNullOrWhiteSpace(form.Model) ? "—" : form.Model,
            form.Year == 0 ? DateTime.Now.Year : form.Year,
            form.Driver,
            form.Capacity == 0 ? 100 : form.Capacity,
            form.Zone,
            form.LastService == default ? "—" : form.LastService.ToString("yyyy-MM-dd"),
            "Active"
        ));
        form = new();
        showForm = false;
    }

    private IEnumerable<VehicleItem> FilteredVehicles => vehicles.Where(v =>
        (string.IsNullOrEmpty(searchQuery) ||
         v.Plate.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
         v.Model.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
         v.Driver.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(typeFilter) || v.Type == typeFilter) &&
        (string.IsNullOrEmpty(statusFilter) || v.Status == statusFilter)
    );

    record VehicleItem(string Plate, string Type, string Model, int Year,
                       string Driver, int Capacity, string Zone,
                       string LastService, string Status);

    class VehicleForm
    {
        public string Plate { get; set; } = "";
        public string Type { get; set; } = "Motorbike";
        public string Model { get; set; } = "";
        public int Year { get; set; }
        public string Driver { get; set; } = "Unassigned";
        public int Capacity { get; set; }
        public string Zone { get; set; } = "Phnom Penh";
        public DateTime LastService { get; set; }
    }

    private List<VehicleItem> vehicles = new()
    {
        new("PP-2341", "Motorbike", "Honda Wave",      2021, "Kheang Vuth",  150, "Phnom Penh",  "2026-05-10", "Active"),
        new("SR-8812", "Van",       "Toyota Hiace",    2020, "Panha Srun",   800, "Siem Reap",   "2026-04-22", "Active"),
        new("KP-4490", "Motorbike", "Yamaha Fino",     2022, "Dara Heng",    150, "Kampot",      "2026-05-30", "Active"),
        new("TK-3301", "Motorbike", "Honda PCX",       2023, "Sokha Meas",   150, "Takeo",       "2026-06-01", "Active"),
        new("SR-1122", "Van",       "Hyundai H-1",     2019, "Chanra Lim",   750, "Siem Reap",   "2026-03-18", "In Maintenance"),
        new("BB-5500", "Truck",     "Isuzu NPR",       2018, "Borin Keo",   3000, "Battambang",  "2026-02-14", "Active"),
        new("PP-9900", "Van",       "Ford Transit",    2021, "Vibol Ros",    900, "Phnom Penh",  "2026-05-05", "Active"),
        new("PP-6677", "Motorbike", "Suzuki Raider",   2020, "Unassigned",   150, "Phnom Penh",  "2026-01-20", "In Maintenance"),
        new("KP-8833", "Motorbike", "Honda Click",     2022, "Sophea Noun",  150, "Kampot",      "2026-06-10", "Active"),
        new("BB-2244", "Truck",     "Mitsubishi Fuso", 2017, "Reaksa Pov",  2500, "Battambang",  "2025-11-30", "Retired"),
    };
}

<style>
    .st-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    /* Stats */
    .vehicle-stats {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 16px;
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-icon-blue {
        background: var(--blue-light);
        color: var(--blue-primary);
    }

    .stat-icon-green {
        background: #e6f9f0;
        color: #1a8a4a;
    }

    .stat-icon-amber {
        background: #fff8e6;
        color: #b45309;
    }

    .stat-icon-red {
        background: #fef2f2;
        color: #dc2626;
    }

    .stat-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1;
    }

    .stat-label {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 3px;
    }

    /* Vehicle Cards */
    .vehicle-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 16px;
    }

    .vehicle-card {
        padding: 20px;
        display: flex;
        flex-direction: column;
    }

    .vehicle-card-top {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .vehicle-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .type-blue {
        background: var(--blue-light);
        color: var(--blue-primary);
    }

    .type-green {
        background: #e6f9f0;
        color: #1a8a4a;
    }

    .type-amber {
        background: #fff8e6;
        color: #b45309;
    }

    .vehicle-plate {
        font-family: monospace;
        font-size: 15px;
        font-weight: 700;
        color: var(--text-primary);
    }

    .vehicle-model {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 2px;
    }

    .vehicle-divider {
        height: 1px;
        background: var(--border-color);
        margin-bottom: 14px;
    }

    .vehicle-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 16px;
    }

    .vinfo-item {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .info-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--text-secondary);
    }

    .info-value {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-primary);
    }

    .vehicle-card-footer {
        display: flex;
        gap: 6px;
        margin-top: auto;
    }

    /* Table extras */
    .plate-tag {
        font-family: monospace;
        font-size: 12px;
        font-weight: 600;
        background: var(--bg-page);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        padding: 2px 7px;
        color: var(--text-primary);
    }

    .type-chip {
        display: inline-flex;
        align-items: center;
        padding: 2px 9px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    /* Modal */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.35);
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-card {
        background: #fff;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        width: 520px;
        max-width: calc(100vw - 32px);
        display: flex;
        flex-direction: column;
        max-height: calc(100vh - 48px);
        overflow: hidden;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px;
        border-bottom: 1px solid var(--border-color);
    }

    .modal-body {
        padding: 24px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border-color);
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .form-row {
        display: flex;
        gap: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
    }

    .form-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--text-secondary);
    }

    .form-input {
        padding: 9px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        color: var(--text-primary);
        background: #fff;
        outline: none;
        width: 100%;
        font-family: inherit;
        transition: border-color .15s, box-shadow .15s;
    }

        .form-input:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    .st-select {
        padding: 8px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        background: #fff;
        color: var(--text-primary);
        outline: none;
        cursor: pointer;
    }

        .st-select:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    @@media (max-width: 900px) {
        .vehicle-stats {
            grid-template-columns: repeat(2,1fr);
        }

        .vehicle-grid {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media (max-width: 600px) {
        .vehicle-grid {
            grid-template-columns: 1fr;
        }

        .form-row {
            flex-direction: column;
        }
    }
</style>
