@page "/payments"
@layout MainLayout
@rendermode InteractiveServer

<PageTitle>Payments — SwiftTrack</PageTitle>

<div class="st-page-header">
    <div>
        <h1 class="st-page-title">Payments</h1>
        <p class="st-page-sub">Track invoices, collections, and outstanding balances</p>
    </div>
    <button class="st-btn st-btn-primary" @onclick="@(() => showForm = true)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        Record Payment
    </button>
</div>

<!-- Stats -->
<div class="payment-stats">
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-blue">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
        </div>
        <div>
            <div class="stat-value">$@TotalRevenue.ToString("N2")</div>
            <div class="stat-label">Total Collected</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
        </div>
        <div>
            <div class="stat-value">@PaidCount</div>
            <div class="stat-label">Paid</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-amber">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
        </div>
        <div>
            <div class="stat-value">@PendingCount</div>
            <div class="stat-label">Pending</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="4.93" y1="4.93" x2="19.07" y2="19.07" /></svg>
        </div>
        <div>
            <div class="stat-value">@OverdueCount</div>
            <div class="stat-label">Overdue</div>
        </div>
    </div>
</div>

<!-- Modal -->
@if (showForm)
{
    <div class="modal-backdrop" @onclick="@(() => showForm = false)">
        <div class="modal-card" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="st-page-title" style="font-size:16px;">Record Payment</h2>
                <button class="st-btn st-btn-ghost" style="padding:4px 8px;" @onclick="@(() => showForm = false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Tracking ID</label>
                        <input class="form-input" type="text" placeholder="e.g. TRK-001234" @bind="form.TrackingId" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Customer</label>
                        <input class="form-input" type="text" placeholder="e.g. San Tin" @bind="form.Customer" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Amount (USD)</label>
                        <input class="form-input" type="number" step="0.01" placeholder="e.g. 25.00" @bind="form.Amount" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Method</label>
                        <select class="form-input" @bind="form.Method">
                            <option value="Cash">Cash</option>
                            <option value="Bank Transfer">Bank Transfer</option>
                            <option value="Credit Card">Credit Card</option>
                            <option value="ABA Pay">ABA Pay</option>
                            <option value="Wing Money">Wing Money</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Date</label>
                        <input class="form-input" type="date" @bind="form.Date" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select class="form-input" @bind="form.Status">
                            <option value="Paid">Paid</option>
                            <option value="Pending">Pending</option>
                            <option value="Overdue">Overdue</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="st-btn st-btn-ghost" @onclick="@(() => showForm = false)">Cancel</button>
                <button class="st-btn st-btn-primary" @onclick="HandleSubmit">Record Payment</button>
            </div>
        </div>
    </div>
}

<!-- Table -->
<div class="st-card" style="margin-top:24px;">
    <div class="st-card-header">
        <h2 class="st-page-title" style="font-size:16px;">All Payments</h2>
        <div style="display:flex; gap:10px; align-items:center;">
            <div class="st-search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search payments..." @bind="searchQuery" @bind:event="oninput" />
            </div>
            <select class="st-select" @bind="methodFilter">
                <option value="">All Methods</option>
                <option value="Cash">Cash</option>
                <option value="Bank Transfer">Bank Transfer</option>
                <option value="Credit Card">Credit Card</option>
                <option value="ABA Pay">ABA Pay</option>
                <option value="Wing Money">Wing Money</option>
            </select>
            <select class="st-select" @bind="statusFilter">
                <option value="">All Status</option>
                <option value="Paid">Paid</option>
                <option value="Pending">Pending</option>
                <option value="Overdue">Overdue</option>
            </select>
        </div>
    </div>
    <div class="st-card-body" style="padding:0;">
        <table class="st-table">
            <thead>
                <tr>
                    <th>Payment ID</th>
                    <th>Tracking ID</th>
                    <th>Customer</th>
                    <th>Amount</th>
                    <th>Method</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in FilteredPayments)
                {
                    <tr>
                        <td><span class="plate-tag">@p.Id</span></td>
                        <td>@p.TrackingId</td>
                        <td style="font-weight:500;">@p.Customer</td>
                        <td class="amount-cell">$@p.Amount.ToString("N2")</td>
                        <td>@p.Method</td>
                        <td>@p.Date</td>
                        <td><span class="st-badge @GetStatusBadge(p.Status)">@p.Status</span></td>
                        <td>
                            <div style="display:flex; gap:6px;">
                                <button class="st-btn st-btn-ghost" style="padding:4px 8px; font-size:12px;">View</button>
                                <button class="st-btn st-btn-outline" style="padding:4px 8px; font-size:12px;">Edit</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private string searchQuery = "";
    private string methodFilter = "";
    private string statusFilter = "";
    private bool showForm = false;
    private PaymentForm form = new();

    private decimal TotalRevenue => payments.Where(p => p.Status == "Paid").Sum(p => p.Amount);
    private int PaidCount => payments.Count(p => p.Status == "Paid");
    private int PendingCount => payments.Count(p => p.Status == "Pending");
    private int OverdueCount => payments.Count(p => p.Status == "Overdue");

    private string GetStatusBadge(string s) => s switch
    {
        "Paid" => "st-badge-green",
        "Pending" => "st-badge-amber",
        "Overdue" => "st-badge-red",
        _ => "st-badge-gray"
    };

    private void HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.Customer) || form.Amount <= 0) return;
        var nextNumber = 3000 + payments.Count + 1;
        payments.Insert(0, new PaymentItem(
            $"PAY-{nextNumber}",
            string.IsNullOrWhiteSpace(form.TrackingId) ? "—" : form.TrackingId.ToUpper(),
            form.Customer,
            form.Amount,
            form.Method,
            form.Date == default ? DateTime.Now.ToString("yyyy-MM-dd") : form.Date.ToString("yyyy-MM-dd"),
            form.Status
        ));
        form = new();
        showForm = false;
    }

    private IEnumerable<PaymentItem> FilteredPayments => payments.Where(p =>
        (string.IsNullOrEmpty(searchQuery) ||
         p.Id.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
         p.TrackingId.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
         p.Customer.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(methodFilter) || p.Method == methodFilter) &&
        (string.IsNullOrEmpty(statusFilter) || p.Status == statusFilter)
    );

    record PaymentItem(string Id, string TrackingId, string Customer, decimal Amount,
                       string Method, string Date, string Status);

    class PaymentForm
    {
        public string TrackingId { get; set; } = "";
        public string Customer { get; set; } = "";
        public decimal Amount { get; set; }
        public string Method { get; set; } = "Cash";
        public DateTime Date { get; set; }
        public string Status { get; set; } = "Paid";
    }

    private List<PaymentItem> payments = new()
    {
        new("PAY-3001", "TRK-001234", "San Tin",     12.50m, "Cash",           "2026-06-15", "Paid"),
        new("PAY-3002", "TRK-001235", "Kosal Rin",    45.00m, "ABA Pay",        "2026-06-16", "Pending"),
        new("PAY-3003", "TRK-001236", "Pisey Lim",    28.75m, "Bank Transfer",  "2026-06-16", "Pending"),
        new("PAY-3004", "TRK-001237", "Ratana Ok",    60.00m, "Credit Card",    "2026-06-14", "Overdue"),
        new("PAY-3005", "TRK-001238", "Sreyla Oun",   15.20m, "Cash",           "2026-06-13", "Paid"),
        new("PAY-3006", "TRK-001239", "Davan Ros",    33.00m, "Wing Money",     "2026-06-17", "Pending"),
        new("PAY-3007", "TRK-001102", "Mony Chan",    18.40m, "ABA Pay",        "2026-06-10", "Paid"),
        new("PAY-3008", "TRK-001098", "Vanna Keo",    52.00m, "Bank Transfer",  "2026-05-28", "Overdue"),
        new("PAY-3009", "TRK-001075", "Sothy Prak",    9.99m, "Cash",           "2026-05-20", "Paid"),
        new("PAY-3010", "TRK-001050", "Bopha Nhem",   41.30m, "Credit Card",    "2026-05-15", "Paid"),
        new("PAY-3011", "TRK-001022", "Chanthy Im",   22.60m, "Wing Money",     "2026-05-02", "Paid"),
        new("PAY-3012", "TRK-000998", "Dara Sok",     67.00m, "ABA Pay",        "2026-04-18", "Overdue"),
    };
}

<style>
    .st-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    /* Stats */
    .payment-stats {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 16px;
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-icon-blue {
        background: var(--blue-light);
        color: var(--blue-primary);
    }

    .stat-icon-green {
        background: #e6f9f0;
        color: #1a8a4a;
    }

    .stat-icon-amber {
        background: #fff8e6;
        color: #b45309;
    }

    .stat-icon-red {
        background: #fef2f2;
        color: #dc2626;
    }

    .stat-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1;
    }

    .stat-label {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 3px;
    }

    /* Table extras */
    .plate-tag {
        font-family: monospace;
        font-size: 12px;
        font-weight: 600;
        background: var(--bg-page);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        padding: 2px 7px;
        color: var(--text-primary);
    }

    .amount-cell {
        font-weight: 600;
        color: var(--text-primary);
    }

    /* Modal */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.35);
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-card {
        background: #fff;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        width: 520px;
        max-width: calc(100vw - 32px);
        display: flex;
        flex-direction: column;
        max-height: calc(100vh - 48px);
        overflow: hidden;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px;
        border-bottom: 1px solid var(--border-color);
    }

    .modal-body {
        padding: 24px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border-color);
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .form-row {
        display: flex;
        gap: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
    }

    .form-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--text-secondary);
    }

    .form-input {
        padding: 9px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        color: var(--text-primary);
        background: #fff;
        outline: none;
        width: 100%;
        font-family: inherit;
        transition: border-color .15s, box-shadow .15s;
    }

        .form-input:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    .st-select {
        padding: 8px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        background: #fff;
        color: var(--text-primary);
        outline: none;
        cursor: pointer;
    }

        .st-select:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    @@media (max-width: 900px) {
        .payment-stats {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media (max-width: 600px) {
        .form-row {
            flex-direction: column;
        }
    }
</style>
