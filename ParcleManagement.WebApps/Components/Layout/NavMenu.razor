@inject NavigationManager Nav

<nav class="navmenu">
    <NavLink href="/" Match="NavLinkMatch.All" class="nm-item">
        <svg class="nm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
        </svg>
        <span>Dashboard</span>
    </NavLink>
    <NavLink href="/parcels" class="nm-item">
        <svg class="nm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l2-1.14" />
        </svg>
        <span>Parcels</span>
    </NavLink>
    <NavLink href="/tracking" class="nm-item">
        <svg class="nm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" />
            <circle cx="12" cy="9" r="2.5" />
        </svg>
        <span>Tracking</span>
    </NavLink>
    <NavLink href="/assignments" class="nm-item">
        <svg class="nm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13" rx="2" />
            <path d="M16 8h5l2 5v3h-7V8z" />
            <circle cx="5.5" cy="18.5" r="2.5" />
            <circle cx="18.5" cy="18.5" r="2.5" />
        </svg>
        <span>Assign</span>
    </NavLink>
    <NavLink href="/users" class="nm-item">
        <svg class="nm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
        </svg>
        <span>Users</span>
    </NavLink>
</nav>

<style>
    .navmenu {
        display: none; /* hidden on desktop — sidebar handles nav */
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--white);
        border-top: 1px solid var(--border-color);
        z-index: 200;
        padding: 6px 0 env(safe-area-inset-bottom, 0);
        flex-direction: row;
        justify-content: space-around;
    }

    .nm-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
        padding: 6px 12px;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 10.5px;
        font-weight: 500;
        border-radius: var(--radius-sm);
        transition: color .12s;
        min-width: 56px;
    }

        .nm-item:hover, .nm-item.active {
            color: var(--blue-primary);
        }

    .nm-icon {
        width: 20px;
        height: 20px;
    }

    @@media (max-width: 768px) {
        .navmenu {
            display: flex;
        }
    }
</style>
