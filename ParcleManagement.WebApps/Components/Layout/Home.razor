@page "/home"
@layout MainLayout

@attribute [Authorize]

@rendermode InteractiveServer

<PageTitle>Dashboard — SwiftTrack</PageTitle>

<div class="st-page-header">
    <div>
        <h1 class="st-page-title">Dashboard</h1>
        <p class="st-page-sub">Overview of parcels, fleet, and revenue</p>
    </div>
    <span class="today-tag">@DateTime.Now.ToString("ddd, dd MMM yyyy")</span>
</div>

<!-- Primary Stats -->
<div class="dash-stats dash-stats-4">
    @foreach (var s in primaryStats)
    {
        <div class="st-card stat-card">
            <div class="stat-icon @s.ColorClass">
                @((MarkupString)s.IconSvg)
            </div>
            <div>
                <div class="stat-value">@s.Value</div>
                <div class="stat-label">@s.Label</div>
                @if (!string.IsNullOrEmpty(s.Trend))
                {
                    <div class="trend-up">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17" /><polyline points="16 7 22 7 22 13" /></svg>
                        @s.Trend
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Secondary Stats -->
<div class="dash-stats dash-stats-3">
    @foreach (var s in secondaryStats)
    {
        <div class="st-card stat-card">
            <div class="stat-icon @s.ColorClass">
                @((MarkupString)s.IconSvg)
            </div>
            <div>
                <div class="stat-value">@s.Value</div>
                <div class="stat-label">@s.Label</div>
                @if (!string.IsNullOrEmpty(s.Trend))
                {
                    <div class="trend-up">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17" /><polyline points="16 7 22 7 22 13" /></svg>
                        @s.Trend
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Charts row -->
<div class="dash-row">
    <div class="st-card dash-panel">
        <div class="st-card-header" style="padding:0 0 16px 0; border:none;">
            <h2 class="st-page-title" style="font-size:15px;">Parcels This Week</h2>
        </div>
        <div class="bar-chart">
            @foreach (var d in weeklyParcels)
            {
                <div class="bar-col">
                    <span class="bar-value">@d.Count</span>
                    <div class="bar-track">
                        <div class="bar-fill @(d.IsToday ? "bar-fill-today" : "")" style="height:@((d.Count * 100.0 / maxWeeklyParcels).ToString("0.0"))%;"></div>
                    </div>
                    <span class="bar-label @(d.IsToday ? "bar-label-today" : "")">@d.Day</span>
                </div>
            }
        </div>
    </div>

    <div class="st-card dash-panel">
        <div class="st-card-header" style="padding:0 0 16px 0; border:none;">
            <h2 class="st-page-title" style="font-size:15px;">Parcel Status Breakdown</h2>
        </div>
        <div class="donut-row">
            <div class="donut-chart" style="background:@DonutGradient;">
                <div class="donut-hole">
                    <span class="donut-total">@TotalParcelsForBreakdown</span>
                    <span class="donut-total-label">parcels</span>
                </div>
            </div>
            <div class="donut-legend">
                @foreach (var item in parcelBreakdown)
                {
                    <div class="legend-row">
                        <span class="legend-dot" style="background:@item.Color;"></span>
                        <span class="legend-label">@item.Label</span>
                        <span class="legend-value">@item.Count</span>
                        <span class="legend-pct">@((item.Count * 100.0 / TotalParcelsForBreakdown).ToString("0.0"))%</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Tables row -->
<div class="dash-row">
    <div class="st-card dash-panel" style="padding:0;">
        <div class="st-card-header">
            <h2 class="st-page-title" style="font-size:15px;">Recent Parcels</h2>
            <a class="st-btn st-btn-ghost" style="font-size:12px; padding:5px 10px;" href="/parcels">View All</a>
        </div>
        <table class="st-table">
            <thead>
                <tr>
                    <th>Tracking ID</th>
                    <th>Recipient</th>
                    <th>Destination</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in recentParcels)
                {
                    <tr>
                        <td><span class="plate-tag">@p.TrackingId</span></td>
                        <td>@p.Recipient</td>
                        <td>@p.Destination</td>
                        <td><span class="st-badge @GetParcelBadge(p.Status)">@p.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="st-card dash-panel">
        <div class="st-card-header" style="padding:0 0 16px 0; border:none;">
            <h2 class="st-page-title" style="font-size:15px;">Fleet Snapshot</h2>
            <a class="st-btn st-btn-ghost" style="font-size:12px; padding:5px 10px;" href="/vehicles">View All</a>
        </div>
        <div class="fleet-bar">
            <div class="fleet-seg" style="flex:@activeVehicles; background:#1a8a4a;"></div>
            <div class="fleet-seg" style="flex:@maintenanceVehicles; background:#b45309;"></div>
            <div class="fleet-seg" style="flex:@retiredVehicles; background:#dc2626;"></div>
        </div>
        <div class="fleet-legend">
            <div class="legend-row">
                <span class="legend-dot" style="background:#1a8a4a;"></span>
                <span class="legend-label">Active</span>
                <span class="legend-value">@activeVehicles</span>
            </div>
            <div class="legend-row">
                <span class="legend-dot" style="background:#b45309;"></span>
                <span class="legend-label">In Maintenance</span>
                <span class="legend-value">@maintenanceVehicles</span>
            </div>
            <div class="legend-row">
                <span class="legend-dot" style="background:#dc2626;"></span>
                <span class="legend-label">Retired</span>
                <span class="legend-value">@retiredVehicles</span>
            </div>
        </div>
        <div class="settings-divider"></div>
        <div class="attention-title">Needs Attention</div>
        @foreach (var v in vehiclesNeedingService)
        {
            <div class="attention-row">
                <span class="attention-dot"></span>
                <div style="flex:1; min-width:0;">
                    <div class="attention-plate">@v.Plate · @v.Model</div>
                    <div class="attention-sub">Last service @v.LastService</div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Recent payments -->
<div class="st-card" style="margin-top:24px; padding:0;">
    <div class="st-card-header">
        <h2 class="st-page-title" style="font-size:15px;">Recent Payments</h2>
        <a class="st-btn st-btn-ghost" style="font-size:12px; padding:5px 10px;" href="/payments">View All</a>
    </div>
    <table class="st-table">
        <thead>
            <tr>
                <th>Payment ID</th>
                <th>Customer</th>
                <th>Method</th>
                <th>Date</th>
                <th>Amount</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in recentPayments)
            {
                <tr>
                    <td><span class="plate-tag">@p.Id</span></td>
                    <td style="font-weight:500;">@p.Customer</td>
                    <td>@p.Method</td>
                    <td>@p.Date</td>
                    <td class="amount-cell">$@p.Amount.ToString("N2")</td>
                    <td><span class="st-badge @GetPaymentBadge(p.Status)">@p.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private int activeVehicles = 22;
    private int maintenanceVehicles = 9;
    private int retiredVehicles = 5;

    private List<(string Day, int Count, bool IsToday)> weeklyParcels = new()
    {
        ("Thu", 178, false),
        ("Fri", 205, false),
        ("Sat", 162, false),
        ("Sun", 140, false),
        ("Mon", 196, false),
        ("Tue", 230, false),
        ("Wed", 264, true),
    };

    private int maxWeeklyParcels => weeklyParcels.Max(d => d.Count);

    private List<(string Label, int Count, string Color)> parcelBreakdown = new()
    {
        ("Delivered",  891, "#1a8a4a"),
        ("In Transit", 290, "#1a6fdb"),
        ("Pending",     52, "#b45309"),
        ("Failed",      51, "#dc2626"),
    };

    private int TotalParcelsForBreakdown => parcelBreakdown.Sum(x => x.Count);

    private string DonutGradient
    {
        get
        {
            var total = TotalParcelsForBreakdown;
            double cumulative = 0;
            var stops = new List<string>();
            foreach (var item in parcelBreakdown)
            {
                var start = cumulative / total * 100;
                cumulative += item.Count;
                var end = cumulative / total * 100;
                stops.Add($"{item.Color} {start.ToString("0.0")}% {end.ToString("0.0")}%");
            }
            return $"conic-gradient({string.Join(", ", stops)})";
        }
    }

    private List<(string TrackingId, string Recipient, string Destination, string Status)> recentParcels = new()
    {
        ("TRK-001239", "Chanthy Im", "Phnom Penh", "In Transit"),
        ("TRK-001236", "Vanna Keo",  "Battambang", "Pending"),
        ("TRK-001235", "Mony Chan",  "Siem Reap",  "In Transit"),
        ("TRK-001234", "Dara Sok",   "Phnom Penh", "Delivered"),
        ("TRK-001237", "Sothy Prak", "Kampot",     "Failed"),
    };

    private List<(string Plate, string Model, string LastService)> vehiclesNeedingService = new()
    {
        ("SR-1122", "Hyundai H-1",   "2026-03-18"),
        ("PP-6677", "Suzuki Raider", "2026-01-20"),
    };

    private List<(string Id, string Customer, decimal Amount, string Method, string Date, string Status)> recentPayments = new()
    {
        ("PAY-3006", "Davan Ros",  33.00m, "Wing Money",    "2026-06-17", "Pending"),
        ("PAY-3002", "Kosal Rin",  45.00m, "ABA Pay",       "2026-06-16", "Pending"),
        ("PAY-3003", "Pisey Lim",  28.75m, "Bank Transfer", "2026-06-16", "Pending"),
        ("PAY-3001", "San Tin",    12.50m, "Cash",          "2026-06-15", "Paid"),
        ("PAY-3004", "Ratana Ok",  60.00m, "Credit Card",   "2026-06-14", "Overdue"),
    };

    private string GetParcelBadge(string s) => s switch
    {
        "Delivered" => "st-badge-green",
        "In Transit" => "st-badge-blue",
        "Pending" => "st-badge-amber",
        "Failed" => "st-badge-red",
        _ => "st-badge-gray"
    };

    private string GetPaymentBadge(string s) => s switch
    {
        "Paid" => "st-badge-green",
        "Pending" => "st-badge-amber",
        "Overdue" => "st-badge-red",
        _ => "st-badge-gray"
    };

    private List<(string Label, string Value, string Trend, string IconSvg, string ColorClass)> primaryStats = new()
    {
        ("Total Parcels", "1,284", "+8% this month",
            "<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"7\" width=\"18\" height=\"13\" rx=\"1\"/><path d=\"M3 7l9-4 9 4\"/><line x1=\"12\" y1=\"11\" x2=\"12\" y2=\"20\"/></svg>",
            "stat-icon-blue"),
        ("In Transit", "290", "",
            "<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>",
            "stat-icon-amber"),
        ("Delivered", "891", "+5% this month",
            "<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>",
            "stat-icon-green"),
        ("Failed", "51", "",
            "<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"4.93\" y1=\"4.93\" x2=\"19.07\" y2=\"19.07\"/></svg>",
            "stat-icon-red"),
    };

    private List<(string Label, string Value, string Trend, string IconSvg, string ColorClass)> secondaryStats = new()
    {
        ("Active Vehicles", "22 / 36", "",
            "<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"1\" y=\"6\" width=\"22\" height=\"12\" rx=\"2\"/><path d=\"M1 12h22\"/><circle cx=\"6\" cy=\"20\" r=\"2\"/><circle cx=\"18\" cy=\"20\" r=\"2\"/></svg>",
            "stat-icon-blue"),
        ("On-Route Drivers", "18", "",
            "<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"7\" r=\"4\"/><path d=\"M5.5 21a6.5 6.5 0 0 1 13 0\"/></svg>",
            "stat-icon-green"),
        ("Revenue This Month", "$24,560", "+12% vs last month",
            "<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"12\" y1=\"1\" x2=\"12\" y2=\"23\"/><path d=\"M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6\"/></svg>",
            "stat-icon-blue"),
    };
}

<style>
    .st-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .today-tag {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-secondary);
        background: var(--bg-page);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        padding: 6px 14px;
    }

    /* Stats */
    .dash-stats {
        display: grid;
        gap: 16px;
        margin-bottom: 16px;
    }

    .dash-stats-4 {
        grid-template-columns: repeat(4,1fr);
    }

    .dash-stats-3 {
        grid-template-columns: repeat(3,1fr);
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-icon-blue {
        background: var(--blue-light);
        color: var(--blue-primary);
    }

    .stat-icon-green {
        background: #e6f9f0;
        color: #1a8a4a;
    }

    .stat-icon-amber {
        background: #fff8e6;
        color: #b45309;
    }

    .stat-icon-red {
        background: #fef2f2;
        color: #dc2626;
    }

    .stat-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1;
    }

    .stat-label {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 3px;
    }

    .trend-up {
        display: flex;
        align-items: center;
        gap: 3px;
        font-size: 11px;
        font-weight: 600;
        color: #1a8a4a;
        margin-top: 6px;
    }

    /* Layout rows */
    .dash-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 8px;
    }

    .dash-panel {
        padding: 22px;
    }

    /* Bar chart */
    .bar-chart {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 10px;
        height: 180px;
        padding-top: 8px;
    }

    .bar-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        flex: 1;
        height: 100%;
        justify-content: flex-end;
    }

    .bar-value {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-secondary);
    }

    .bar-track {
        width: 100%;
        flex: 1;
        display: flex;
        align-items: flex-end;
        background: var(--bg-page);
        border-radius: 6px 6px 0 0;
        overflow: hidden;
    }

    .bar-fill {
        width: 100%;
        background: #c7d9f5;
        border-radius: 6px 6px 0 0;
        transition: height .2s;
    }

    .bar-fill-today {
        background: var(--blue-primary);
    }

    .bar-label {
        font-size: 11px;
        color: var(--text-secondary);
    }

    .bar-label-today {
        color: var(--blue-primary);
        font-weight: 700;
    }

    /* Donut */
    .donut-row {
        display: flex;
        align-items: center;
        gap: 28px;
    }

    .donut-chart {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        flex-shrink: 0;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .donut-hole {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        background: #fff;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .donut-total {
        font-size: 18px;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1;
    }

    .donut-total-label {
        font-size: 11px;
        color: var(--text-secondary);
        margin-top: 2px;
    }

    .donut-legend {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
    }

    .legend-row {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
    }

    .legend-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .legend-label {
        color: var(--text-secondary);
        flex: 1;
    }

    .legend-value {
        font-weight: 600;
        color: var(--text-primary);
    }

    .legend-pct {
        font-size: 12px;
        color: var(--text-secondary);
        width: 42px;
        text-align: right;
    }

    /* Fleet snapshot */
    .fleet-bar {
        display: flex;
        height: 12px;
        border-radius: 999px;
        overflow: hidden;
        background: var(--bg-page);
        margin-bottom: 16px;
    }

    .fleet-seg {
        height: 100%;
    }

    .fleet-legend {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .settings-divider {
        height: 1px;
        background: var(--border-color);
        margin: 16px 0;
    }

    .attention-title {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--text-secondary);
        margin-bottom: 10px;
    }

    .attention-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
    }

    .attention-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #b45309;
        flex-shrink: 0;
    }

    .attention-plate {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .attention-sub {
        font-size: 11px;
        color: var(--text-secondary);
        margin-top: 1px;
    }

    /* Table extras */
    .plate-tag {
        font-family: monospace;
        font-size: 12px;
        font-weight: 600;
        background: var(--bg-page);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        padding: 2px 7px;
        color: var(--text-primary);
    }

    .amount-cell {
        font-weight: 600;
        color: var(--text-primary);
    }

    @@media (max-width: 1100px) {
        .dash-stats-4, .dash-stats-3 {
            grid-template-columns: repeat(2,1fr);
        }

        .dash-row {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 600px) {
        .dash-stats-4, .dash-stats-3 {
            grid-template-columns: 1fr;
        }

        .donut-row {
            flex-direction: column;
        }
    }
</style>
