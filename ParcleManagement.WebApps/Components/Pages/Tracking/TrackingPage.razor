<style>
    .st-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    /* ── Search bar ── */
    .track-search-card {
        padding: 20px;
        margin-bottom: 16px;
    }

    .track-search-inner {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .track-search-box {
        flex: 1;
    }

        .track-search-box input {
            width: 100%;
            font-size: 14px;
        }

    /* ── Detail grid ── */
    .track-detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 0;
    }

    /* ── Detail items ── */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .detail-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-secondary);
        font-weight: 600;
    }

    .detail-value {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-primary);
    }

    /* ── Driver row ── */
    .driver-row {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .driver-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--blue-light);
        color: var(--blue-primary);
        font-weight: 700;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .driver-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .driver-meta {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 2px;
    }

    /* ── Timeline ── */
    .timeline {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .timeline-item {
        display: flex;
        gap: 14px;
        padding-bottom: 20px;
    }

        .timeline-item:last-child {
            padding-bottom: 0;
        }

    .timeline-line-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
        width: 20px;
    }

    .timeline-dot {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .dot-active {
        background: var(--blue-primary);
        color: #fff;
    }

    .dot-done {
        background: #e6f9f0;
        border: 2px solid #1a8a4a;
    }

    .dot-muted {
        background: var(--border-color);
        border: 2px solid #ccc;
    }

    .timeline-connector {
        width: 2px;
        flex: 1;
        min-height: 16px;
        background: var(--border-color);
        margin-top: 4px;
    }

    .timeline-body {
        padding-bottom: 4px;
    }

    .timeline-event {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .timeline-location {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 3px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .timeline-time {
        font-size: 11px;
        color: var(--text-secondary);
        margin-top: 2px;
    }

    /* ── Shared ── */
    .tracking-id {
        font-family: monospace;
        font-size: 13px;
        color: var(--blue-primary);
        font-weight: 600;
    }

    .st-select {
        padding: 8px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        background: #fff;
        color: var(--text-primary);
        outline: none;
        cursor: pointer;
    }

        .st-select:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    @@media (max-width: 900px) {
        .track-detail-grid {
            grid-template-columns: 1fr;
        }

        .track-search-inner {
            flex-direction: column;
        }

            .track-search-inner .st-btn {
                width: 100%;
            }
    }
</style>
