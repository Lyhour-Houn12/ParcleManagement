@page "/parcels"
@layout MainLayout
@rendermode InteractiveServer



<PageTitle>Parcels — SwiftTrack</PageTitle>

<ParcelForm IsVisible="showForm"
            OnClose="@(() => showForm = false)"
            OnSubmit="HandleParcelCreated" />

<ParcelDetail IsVisible="showDetail"
              Parcel="selectedParcel"
              OnClose="@(() => showDetail = false)" />

<div class="st-page-header">
    <div>
        <h1 class="st-page-title">Parcels</h1>
        <p class="st-page-sub">Manage and track all parcels in the system</p>
    </div>
    <button class="st-btn st-btn-primary" @onclick="@(() => showForm = true)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        New Parcel
    </button>
</div>

<!-- Stats Row -->
<div class="parcel-stats">
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-blue">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" /></svg>
        </div>
        <div>
            <div class="stat-value">1,284</div>
            <div class="stat-label">Total Parcels</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-amber">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
        </div>
        <div>
            <div class="stat-value">342</div>
            <div class="stat-label">In Transit</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
        </div>
        <div>
            <div class="stat-value">891</div>
            <div class="stat-label">Delivered</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
        </div>
        <div>
            <div class="stat-value">51</div>
            <div class="stat-label">Failed</div>
        </div>
    </div>
</div>

<!-- Table Card -->
<div class="st-card" style="margin-top: 24px;">
    <div class="st-card-header">
        <div>
            <h2 class="st-page-title" style="font-size:16px;">All Parcels</h2>
        </div>
        <div style="display:flex; gap:10px; align-items:center;">
            <div class="st-search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search parcels..." @bind="searchQuery" @bind:event="oninput" />
            </div>
            <select class="st-select" @bind="statusFilter">
                <option value="">All Status</option>
                <option value="pending">Pending</option>
                <option value="in_transit">In Transit</option>
                <option value="delivered">Delivered</option>
                <option value="failed">Failed</option>
            </select>
        </div>
    </div>
    <div class="st-card-body" style="padding:0;">
        <table class="st-table">
            <thead>
                <tr>
                    <th>Tracking ID</th>
                    <th>Sender</th>
                    <th>Recipient</th>
                    <th>Destination</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var parcel in FilteredParcels)
                {
                    <tr>
                        <td><span class="tracking-id">@parcel.TrackingId</span></td>
                        <td>@parcel.Sender</td>
                        <td>@parcel.Recipient</td>
                        <td>@parcel.Destination</td>
                        <td>
                            <span class="st-badge @GetStatusBadge(parcel.Status)">@parcel.Status</span>
                        </td>
                        <td>@parcel.Date</td>
                        <td>
                            <div style="display:flex; gap:6px;">
                                <button class="st-btn st-btn-ghost" style="padding:4px 8px; font-size:12px;"
                                        @onclick="@(() => ViewParcel(parcel))">
                                    View
                                </button>
                                <button class="st-btn st-btn-outline" style="padding:4px 8px; font-size:12px;">Edit</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private string searchQuery = "";
    private string statusFilter = "";
    private bool showForm = false;
    private bool showDetail = false;
    private ParcelDetail.ParcelItemDetail? selectedParcel;

    // Dummy data — replace with real DB call later
    private List<ParcelItem> parcels = new()
    {
        new("TRK-001234", "San Tin", "Dara Sok", "Phnom Penh", "Delivered", "2026-06-15"),
        new("TRK-001235", "Kosal Rin", "Mony Chan", "Siem Reap", "In Transit", "2026-06-16"),
        new("TRK-001236", "Pisey Lim", "Vanna Keo", "Battambang", "Pending", "2026-06-16"),
        new("TRK-001237", "Ratana Ok", "Sothy Prak", "Kampot", "Failed", "2026-06-14"),
        new("TRK-001238", "Sreyla Oun", "Bopha Nhem", "Takeo", "Delivered", "2026-06-13"),
        new("TRK-001239", "Davan Ros", "Chanthy Im", "Phnom Penh", "In Transit", "2026-06-17"),
    };

    private IEnumerable<ParcelItem> FilteredParcels => parcels
        .Where(p =>
            (string.IsNullOrEmpty(searchQuery) ||
             p.TrackingId.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
             p.Sender.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
             p.Recipient.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(statusFilter) ||
             p.Status.Equals(statusFilter, StringComparison.OrdinalIgnoreCase))
        );

    private string GetStatusBadge(string status) => status switch
    {
        "Delivered" => "st-badge-green",
        "In Transit" => "st-badge-blue",
        "Pending" => "st-badge-amber",
        "Failed" => "st-badge-red",
        _ => "st-badge-gray"
    };

    record ParcelItem(string TrackingId, string Sender, string Recipient, string Destination, string Status, string Date);

    private void HandleParcelCreated(ParcelForm.ParcelFormData data)
    {
        parcels.Insert(0, new ParcelItem(
            $"TRK-{Random.Shared.Next(100000, 999999)}",
            data.SenderName,
            data.RecipientName,
            data.Destination,
            "Pending",
            DateTime.Now.ToString("yyyy-MM-dd")
        ));
        showForm = false;
    }

    private void ViewParcel(ParcelItem parcel)
    {
        selectedParcel = new ParcelDetail.ParcelItemDetail
        {
            TrackingId = parcel.TrackingId,
            Sender = parcel.Sender,
            Recipient = parcel.Recipient,
            Destination = parcel.Destination,
            Status = parcel.Status,
            Date = parcel.Date
        };
        showDetail = true;
    }
}

<style>
    .st-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .parcel-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-icon-blue {
        background: var(--blue-light);
        color: var(--blue-primary);
    }

    .stat-icon-green {
        background: #e6f9f0;
        color: #1a8a4a;
    }

    .stat-icon-amber {
        background: #fff8e6;
        color: #b45309;
    }

    .stat-icon-red {
        background: #fef2f2;
        color: #dc2626;
    }

    .stat-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1;
    }

    .stat-label {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 3px;
    }

    .tracking-id {
        font-family: monospace;
        font-size: 13px;
        color: var(--blue-primary);
        font-weight: 600;
    }

    .st-select {
        padding: 8px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        background: #fff;
        color: var(--text-primary);
        outline: none;
        cursor: pointer;
    }

        .st-select:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    @@media (max-width: 768px) {
        .parcel-stats {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>