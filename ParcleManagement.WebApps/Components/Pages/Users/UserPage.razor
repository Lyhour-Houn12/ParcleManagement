@page "/users"
@layout MainLayout
@rendermode InteractiveServer

<PageTitle>Users — SwiftTrack</PageTitle>

<div class="st-page-header">
    <div>
        <h1 class="st-page-title">Users</h1>
        <p class="st-page-sub">Manage system accounts and access roles</p>
    </div>
    <button class="st-btn st-btn-primary" @onclick="@(() => showForm = true)">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        New User
    </button>
</div>

<!-- Stats -->
<div class="user-stats">
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-blue">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
        </div>
        <div>
            <div class="stat-value">38</div>
            <div class="stat-label">Total Users</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
        </div>
        <div>
            <div class="stat-value">31</div>
            <div class="stat-label">Active</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-amber">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
        </div>
        <div>
            <div class="stat-value">5</div>
            <div class="stat-label">Admins</div>
        </div>
    </div>
    <div class="st-card stat-card">
        <div class="stat-icon stat-icon-red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="4.93" y1="4.93" x2="19.07" y2="19.07" /></svg>
        </div>
        <div>
            <div class="stat-value">7</div>
            <div class="stat-label">Inactive</div>
        </div>
    </div>
</div>

<!-- Modal -->
@if (showForm)
{
    <div class="modal-backdrop" @onclick="@(() => showForm = false)">
        <div class="modal-card" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="st-page-title" style="font-size:16px;">New User</h2>
                <button class="st-btn st-btn-ghost" style="padding:4px 8px;" @onclick="@(() => showForm = false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <input class="form-input" type="text" placeholder="e.g. San Tin" @bind="form.FullName" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Username</label>
                        <input class="form-input" type="text" placeholder="e.g. santin" @bind="form.Username" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-input" type="email" placeholder="e.g. santin@swifttrack.com" @bind="form.Email" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Role</label>
                        <select class="form-input" @bind="form.Role">
                            <option value="Admin">Admin</option>
                            <option value="Manager">Manager</option>
                            <option value="Staff">Staff</option>
                            <option value="Viewer">Viewer</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Phone</label>
                        <input class="form-input" type="text" placeholder="+855 12 000 000" @bind="form.Phone" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="st-btn st-btn-ghost" @onclick="@(() => showForm = false)">Cancel</button>
                <button class="st-btn st-btn-primary" @onclick="HandleSubmit">Create User</button>
            </div>
        </div>
    </div>
}

<!-- Table -->
<div class="st-card" style="margin-top:24px;">
    <div class="st-card-header">
        <h2 class="st-page-title" style="font-size:16px;">All Users</h2>
        <div style="display:flex; gap:10px; align-items:center;">
            <div class="st-search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search users..." @bind="searchQuery" @bind:event="oninput" />
            </div>
            <select class="st-select" @bind="roleFilter">
                <option value="">All Roles</option>
                <option value="Admin">Admin</option>
                <option value="Manager">Manager</option>
                <option value="Staff">Staff</option>
                <option value="Viewer">Viewer</option>
            </select>
            <select class="st-select" @bind="statusFilter">
                <option value="">All Status</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>
    </div>
    <div class="st-card-body" style="padding:0;">
        <table class="st-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in FilteredUsers)
                {
                    <tr>
                        <td>
                            <div class="user-cell">
                                <div class="user-avatar" style="background:@GetAvatarColor(u.Role).bg; color:@GetAvatarColor(u.Role).fg;">
                                    @GetInitials(u.FullName)
                                </div>
                                <span style="font-weight:500;">@u.FullName</span>
                            </div>
                        </td>
                        <td style="color:var(--text-secondary); font-family:monospace;">@@@u.Username</td>
                        <td>@u.Email</td>
                        <td>@u.Phone</td>
                        <td><span class="st-badge @GetRoleBadge(u.Role)">@u.Role</span></td>
                        <td><span class="st-badge @GetStatusBadge(u.Status)">@u.Status</span></td>
                        <td>@u.CreatedDate</td>
                        <td>
                            <div style="display:flex; gap:6px;">
                                <button class="st-btn st-btn-ghost" style="padding:4px 8px; font-size:12px;">Edit</button>
                                <button class="st-btn st-btn-outline" style="padding:4px 8px; font-size:12px; border-color:#dc2626; color:#dc2626;"
                                        @onclick="@(() => ToggleStatus(u))">
                                    @(u.Status == "Active" ? "Disable" : "Enable")
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private string searchQuery = "";
    private string roleFilter = "";
    private string statusFilter = "";
    private bool showForm = false;
    private UserForm form = new();

    private string GetInitials(string name)
    {
        var parts = name.Split(' ');
        return parts.Length >= 2 ? $"{parts[0][0]}{parts[1][0]}" : name[..1];
    }

    private (string bg, string fg) GetAvatarColor(string role) => role switch
    {
        "Admin" => ("#fef2f2", "#dc2626"),
        "Manager" => ("#fff8e6", "#b45309"),
        "Staff" => ("var(--blue-light)", "var(--blue-primary)"),
        _ => ("#f3f4f6", "#6b7280")
    };

    private string GetRoleBadge(string role) => role switch
    {
        "Admin" => "st-badge-red",
        "Manager" => "st-badge-amber",
        "Staff" => "st-badge-blue",
        _ => "st-badge-gray"
    };

    private string GetStatusBadge(string s) =>
        s == "Active" ? "st-badge-green" : "st-badge-gray";

    private void ToggleStatus(UserItem u)
    {
        var idx = users.IndexOf(u);
        users[idx] = u with { Status = u.Status == "Active" ? "Inactive" : "Active" };
    }

    private void HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(form.FullName) || string.IsNullOrWhiteSpace(form.Email)) return;
        users.Insert(0, new UserItem(
            form.FullName,
            string.IsNullOrWhiteSpace(form.Username) ? form.FullName.Replace(" ", "").ToLower() : form.Username,
            form.Email,
            string.IsNullOrWhiteSpace(form.Phone) ? "—" : form.Phone,
            form.Role,
            "Active",
            DateTime.Now.ToString("yyyy-MM-dd")
        ));
        form = new();
        showForm = false;
    }

    private IEnumerable<UserItem> FilteredUsers => users.Where(u =>
        (string.IsNullOrEmpty(searchQuery) ||
         u.FullName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
         u.Username.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
         u.Email.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(roleFilter) || u.Role == roleFilter) &&
        (string.IsNullOrEmpty(statusFilter) || u.Status == statusFilter)
    );

    record UserItem(string FullName, string Username, string Email, string Phone,
                    string Role, string Status, string CreatedDate);

    class UserForm
    {
        public string FullName { get; set; } = "";
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Role { get; set; } = "Staff";
    }

    private List<UserItem> users = new()
    {
        new("San Tin",      "santin",    "santin@swifttrack.com",    "+855 12 345 678", "Admin",   "Active",   "2026-01-10"),
        new("Dara Sok",     "darasok",   "dara@swifttrack.com",      "+855 17 222 333", "Manager", "Active",   "2026-01-12"),
        new("Kosal Rin",    "kosalrin",  "kosal@swifttrack.com",     "+855 96 444 555", "Staff",   "Active",   "2026-02-03"),
        new("Pisey Lim",    "piseylim",  "pisey@swifttrack.com",     "+855 11 666 777", "Staff",   "Active",   "2026-02-15"),
        new("Ratana Ok",    "ratanaok",  "ratana@swifttrack.com",    "+855 78 888 000", "Manager", "Active",   "2026-03-01"),
        new("Sreyla Oun",   "sreylaoun", "sreyla@swifttrack.com",    "+855 12 111 999", "Staff",   "Inactive", "2026-03-20"),
        new("Mony Chan",    "monychan",  "mony@swifttrack.com",      "+855 17 321 654", "Viewer",  "Active",   "2026-04-05"),
        new("Vanna Keo",    "vannakeo",  "vanna@swifttrack.com",     "+855 96 555 888", "Staff",   "Active",   "2026-04-18"),
        new("Sothy Prak",   "sothyprak", "sothy@swifttrack.com",     "+855 11 777 222", "Viewer",  "Inactive", "2026-05-02"),
        new("Chanthy Im",   "chanthyim", "chanthy@swifttrack.com",   "+855 78 333 111", "Admin",   "Active",   "2026-05-14"),
    };
}

<style>
    .st-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .user-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-icon-blue {
        background: var(--blue-light);
        color: var(--blue-primary);
    }

    .stat-icon-green {
        background: #e6f9f0;
        color: #1a8a4a;
    }

    .stat-icon-amber {
        background: #fff8e6;
        color: #b45309;
    }

    .stat-icon-red {
        background: #fef2f2;
        color: #dc2626;
    }

    .stat-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1;
    }

    .stat-label {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 3px;
    }

    .user-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        font-size: 12px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    /* Modal */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.35);
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-card {
        background: #fff;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        width: 500px;
        max-width: calc(100vw - 32px);
        display: flex;
        flex-direction: column;
        max-height: calc(100vh - 48px);
        overflow: hidden;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px;
        border-bottom: 1px solid var(--border-color);
    }

    .modal-body {
        padding: 24px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border-color);
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .form-row {
        display: flex;
        gap: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
    }

    .form-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--text-secondary);
    }

    .form-input {
        padding: 9px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        color: var(--text-primary);
        background: #fff;
        outline: none;
        width: 100%;
        font-family: inherit;
        transition: border-color .15s, box-shadow .15s;
    }

        .form-input:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    .st-select {
        padding: 8px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        background: #fff;
        color: var(--text-primary);
        outline: none;
        cursor: pointer;
    }

        .st-select:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    @@media (max-width: 768px) {
        .user-stats {
            grid-template-columns: repeat(2, 1fr);
        }

        .form-row {
            flex-direction: column;
        }
    }
</style>
