@page "/settings"
@layout MainLayout
@rendermode InteractiveServer

<PageTitle>Settings — SwiftTrack</PageTitle>

<div class="st-page-header">
    <div>
        <h1 class="st-page-title">Settings</h1>
        <p class="st-page-sub">Manage company information, notification preferences, and security</p>
    </div>
</div>

<div class="settings-layout">
    <!-- Tabs -->
    <div class="st-card settings-tabs">
        @foreach (var tab in tabs)
        {
            <button class="settings-tab @(activeTab == tab.Key ? "settings-tab-active" : "")"
                    @onclick="@(() => SelectTab(tab.Key))">
                <span class="settings-tab-icon">@((MarkupString)tab.Icon)</span>
                @tab.Label
            </button>
        }
    </div>

    <!-- Panel -->
    <div class="st-card settings-panel">
        @if (!string.IsNullOrEmpty(savedMessage))
        {
            <div class="settings-saved-banner">@savedMessage</div>
        }

        @if (activeTab == "general")
        {
            <h2 class="st-page-title" style="font-size:16px; margin-bottom:18px;">General</h2>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Company Name</label>
                    <input class="form-input" type="text" @bind="general.CompanyName" />
                </div>
                <div class="form-group">
                    <label class="form-label">Default Zone</label>
                    <select class="form-input" @bind="general.DefaultZone">
                        <option value="Phnom Penh">Phnom Penh</option>
                        <option value="Siem Reap">Siem Reap</option>
                        <option value="Battambang">Battambang</option>
                        <option value="Kampot">Kampot</option>
                        <option value="Takeo">Takeo</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Timezone</label>
                    <select class="form-input" @bind="general.Timezone">
                        <option value="Asia/Phnom_Penh">Asia/Phnom_Penh (UTC+7)</option>
                        <option value="Asia/Bangkok">Asia/Bangkok (UTC+7)</option>
                        <option value="Asia/Singapore">Asia/Singapore (UTC+8)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Currency</label>
                    <select class="form-input" @bind="general.Currency">
                        <option value="USD">USD ($)</option>
                        <option value="KHR">KHR (៛)</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Date Format</label>
                    <select class="form-input" @bind="general.DateFormat">
                        <option value="yyyy-MM-dd">YYYY-MM-DD</option>
                        <option value="dd/MM/yyyy">DD/MM/YYYY</option>
                        <option value="MM/dd/yyyy">MM/DD/YYYY</option>
                    </select>
                </div>
                <div class="form-group"></div>
            </div>
            <div class="settings-actions">
                <button class="st-btn st-btn-primary" @onclick="@(() => Save("General settings saved"))">Save Changes</button>
            </div>
        }
        else if (activeTab == "company")
        {
            <h2 class="st-page-title" style="font-size:16px; margin-bottom:18px;">Company Profile</h2>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Address</label>
                    <input class="form-input" type="text" @bind="company.Address" />
                </div>
                <div class="form-group">
                    <label class="form-label">Tax ID</label>
                    <input class="form-input" type="text" @bind="company.TaxId" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input class="form-input" type="text" @bind="company.Phone" />
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-input" type="email" @bind="company.Email" />
                </div>
            </div>
            <div class="settings-actions">
                <button class="st-btn st-btn-primary" @onclick="@(() => Save("Company profile saved"))">Save Changes</button>
            </div>
        }
        else if (activeTab == "notifications")
        {
            <h2 class="st-page-title" style="font-size:16px; margin-bottom:18px;">Notifications</h2>
            <div class="toggle-row">
                <div>
                    <div class="toggle-title">New parcel created</div>
                    <div class="toggle-sub">Get notified when a new parcel is registered in the system</div>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="notifications.NewParcelAlerts" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="toggle-row">
                <div>
                    <div class="toggle-title">Payment received</div>
                    <div class="toggle-sub">Get notified when a customer payment is recorded</div>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="notifications.PaymentReceivedAlerts" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="toggle-row">
                <div>
                    <div class="toggle-title">Vehicle maintenance due</div>
                    <div class="toggle-sub">Get notified when a vehicle is flagged for service</div>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="notifications.MaintenanceDueAlerts" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="toggle-row">
                <div>
                    <div class="toggle-title">Low driver availability</div>
                    <div class="toggle-sub">Get notified when fewer than 3 drivers are unassigned</div>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="notifications.LowDriverAvailability" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="settings-actions">
                <button class="st-btn st-btn-primary" @onclick="@(() => Save("Notification preferences saved"))">Save Changes</button>
            </div>
        }
        else if (activeTab == "security")
        {
            <h2 class="st-page-title" style="font-size:16px; margin-bottom:18px;">Security</h2>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Current Password</label>
                    <input class="form-input" type="password" @bind="security.CurrentPassword" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">New Password</label>
                    <input class="form-input" type="password" @bind="security.NewPassword" />
                </div>
                <div class="form-group">
                    <label class="form-label">Confirm New Password</label>
                    <input class="form-input" type="password" @bind="security.ConfirmPassword" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(securityError))
            {
                <div class="settings-error-banner">@securityError</div>
            }
            <div class="settings-divider"></div>
            <div class="toggle-row">
                <div>
                    <div class="toggle-title">Two-factor authentication</div>
                    <div class="toggle-sub">Require a one-time code in addition to your password at sign-in</div>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="security.TwoFactorEnabled" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="settings-actions">
                <button class="st-btn st-btn-primary" @onclick="SaveSecurity">Save Changes</button>
            </div>
        }
    </div>
</div>

@code {
    private string activeTab = "general";
    private string savedMessage = "";
    private string securityError = "";

    private GeneralSettings general = new();
    private CompanyProfile company = new();
    private NotificationSettings notifications = new();
    private SecuritySettings security = new();

    private List<(string Key, string Label, string Icon)> tabs = new()
    {
        ("general", "General", "<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z\"/></svg>"),
        ("company", "Company Profile", "<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"7\" width=\"18\" height=\"14\" rx=\"1\"/><path d=\"M9 21V11h6v10\"/><path d=\"M9 7V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3\"/></svg>"),
        ("notifications", "Notifications", "<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9\"/><path d=\"M13.73 21a2 2 0 0 1-3.46 0\"/></svg>"),
        ("security", "Security", "<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>"),
    };

    private void SelectTab(string key)
    {
        activeTab = key;
        savedMessage = "";
        securityError = "";
    }

    private void Save(string message)
    {
        savedMessage = message;
    }

    private void SaveSecurity()
    {
        securityError = "";
        if (!string.IsNullOrEmpty(security.NewPassword) && security.NewPassword != security.ConfirmPassword)
        {
            securityError = "New password and confirmation do not match.";
            return;
        }
        security.CurrentPassword = "";
        security.NewPassword = "";
        security.ConfirmPassword = "";
        Save("Security settings saved");
    }

    class GeneralSettings
    {
        public string CompanyName { get; set; } = "SwiftTrack Logistics";
        public string DefaultZone { get; set; } = "Phnom Penh";
        public string Timezone { get; set; } = "Asia/Phnom_Penh";
        public string Currency { get; set; } = "USD";
        public string DateFormat { get; set; } = "yyyy-MM-dd";
    }

    class CompanyProfile
    {
        public string Address { get; set; } = "12 Street 271, Phnom Penh, Cambodia";
        public string TaxId { get; set; } = "K-00198234";
        public string Phone { get; set; } = "+855 23 555 1234";
        public string Email { get; set; } = "contact@swifttrack.com";
    }

    class NotificationSettings
    {
        public bool NewParcelAlerts { get; set; } = true;
        public bool PaymentReceivedAlerts { get; set; } = true;
        public bool MaintenanceDueAlerts { get; set; } = true;
        public bool LowDriverAvailability { get; set; } = false;
    }

    class SecuritySettings
    {
        public string CurrentPassword { get; set; } = "";
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
        public bool TwoFactorEnabled { get; set; } = false;
    }
}

<style>
    .st-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .settings-layout {
        display: flex;
        gap: 16px;
        align-items: flex-start;
    }

    .settings-tabs {
        width: 220px;
        flex-shrink: 0;
        padding: 10px;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .settings-tab {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: var(--radius-sm);
        border: none;
        background: transparent;
        text-align: left;
        font-size: 13px;
        font-weight: 500;
        color: var(--text-secondary);
        cursor: pointer;
        transition: background .15s, color .15s;
        width: 100%;
    }

        .settings-tab:hover {
            background: var(--bg-page);
        }

    .settings-tab-active {
        background: var(--blue-light);
        color: var(--blue-primary);
    }

        .settings-tab-active:hover {
            background: var(--blue-light);
        }

    .settings-tab-icon {
        display: flex;
        flex-shrink: 0;
    }

    .settings-panel {
        flex: 1;
        padding: 24px;
        min-width: 0;
    }

    .settings-saved-banner {
        background: #e6f9f0;
        color: #1a8a4a;
        font-size: 13px;
        font-weight: 500;
        padding: 10px 14px;
        border-radius: var(--radius-sm);
        margin-bottom: 18px;
    }

    .settings-error-banner {
        background: #fef2f2;
        color: #dc2626;
        font-size: 13px;
        font-weight: 500;
        padding: 10px 14px;
        border-radius: var(--radius-sm);
        margin-bottom: 4px;
    }

    .settings-divider {
        height: 1px;
        background: var(--border-color);
        margin: 18px 0;
    }

    .settings-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 22px;
        padding-top: 18px;
        border-top: 1px solid var(--border-color);
    }

    /* Form */
    .form-row {
        display: flex;
        gap: 16px;
        margin-bottom: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
    }

    .form-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--text-secondary);
    }

    .form-input {
        padding: 9px 12px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 13px;
        color: var(--text-primary);
        background: #fff;
        outline: none;
        width: 100%;
        font-family: inherit;
        transition: border-color .15s, box-shadow .15s;
    }

        .form-input:focus {
            border-color: var(--blue-primary);
            box-shadow: 0 0 0 3px rgba(26,111,219,.12);
        }

    /* Toggle rows */
    .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 0;
        border-bottom: 1px solid var(--border-color);
    }

        .toggle-row:last-of-type {
            border-bottom: none;
        }

    .toggle-title {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .toggle-sub {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 2px;
    }

    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 40px;
        height: 22px;
        flex-shrink: 0;
        cursor: pointer;
    }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .toggle-slider {
        position: absolute;
        inset: 0;
        background: var(--border-color);
        border-radius: 999px;
        transition: background .15s;
    }

        .toggle-slider::before {
            content: "";
            position: absolute;
            width: 16px;
            height: 16px;
            left: 3px;
            top: 3px;
            background: #fff;
            border-radius: 50%;
            transition: transform .15s;
        }

    .toggle-switch input:checked + .toggle-slider {
        background: var(--blue-primary);
    }

        .toggle-switch input:checked + .toggle-slider::before {
            transform: translateX(18px);
        }

    @@media (max-width: 760px) {
        .settings-layout {
            flex-direction: column;
        }

        .settings-tabs {
            width: 100%;
            flex-direction: row;
            overflow-x: auto;
        }

        .form-row {
            flex-direction: column;
        }
    }
</style>
